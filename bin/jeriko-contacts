#!/usr/bin/env node
const { parseArgs, ok, fail, run, escapeAppleScript: esc } = require('../lib/cli');
const { execSync } = require('child_process');

function osascript(script) {
  return execSync('osascript', { input: script, encoding: 'utf-8', timeout: 15000 }).trim();
}

run(async () => {
  const { flags, positional } = parseArgs(process.argv);

  if (flags.search) {
    const query = esc(typeof flags.search === 'string' ? flags.search : positional[0]);
    if (!query) fail('Usage: jeriko contacts --search <name>');
    const raw = osascript(`
      tell application "Contacts"
        set output to ""
        set matches to every person whose name contains "${query}"
        repeat with p in matches
          set ph to ""
          set em to ""
          try
            set ph to value of first phone of p
          end try
          try
            set em to value of first email of p
          end try
          set output to output & name of p & "|" & ph & "|" & em & linefeed
        end repeat
        return output
      end tell
    `);
    const contacts = raw.split('\n').filter(Boolean).map(line => {
      const [name, phone, email] = line.split('|');
      return { name, phone: phone || null, email: email || null };
    });
    return ok(contacts);
  }

  if (flags.list) {
    const limit = flags.limit ? parseInt(flags.limit) : 20;
    const raw = osascript(`
      tell application "Contacts"
        set output to ""
        set ppl to every person
        set cnt to 0
        repeat with p in ppl
          if cnt >= ${limit} then exit repeat
          set ph to ""
          set em to ""
          try
            set ph to value of first phone of p
          end try
          try
            set em to value of first email of p
          end try
          set output to output & name of p & "|" & ph & "|" & em & linefeed
          set cnt to cnt + 1
        end repeat
        return output
      end tell
    `);
    const contacts = raw.split('\n').filter(Boolean).map(line => {
      const [name, phone, email] = line.split('|');
      return { name, phone: phone || null, email: email || null };
    });
    return ok(contacts);
  }

  fail('Usage: jeriko contacts --search <name>|--list [--limit N]');
});
