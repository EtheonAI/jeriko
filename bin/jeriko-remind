#!/usr/bin/env node
const { parseArgs, ok, fail, run, escapeAppleScript: esc } = require('../lib/cli');
const { execSync } = require('child_process');

function osascript(script) {
  return execSync('osascript', { input: script, encoding: 'utf-8', timeout: 15000 }).trim();
}

run(async () => {
  const { flags, positional } = parseArgs(process.argv);

  if (flags.list) {
    const listName = esc(typeof flags.list === 'string' ? flags.list : 'Reminders');
    const raw = osascript(`
      tell application "Reminders"
        set output to ""
        set rems to reminders of list "${listName}" whose completed is false
        repeat with r in rems
          set dd to ""
          try
            set dd to due date of r as string
          end try
          set output to output & id of r & "|" & name of r & "|" & dd & "|" & priority of r & linefeed
        end repeat
        return output
      end tell
    `);
    const reminders = raw.split('\n').filter(Boolean).map(line => {
      const [id, name, due, priority] = line.split('|');
      return { id, name, due: due || null, priority: parseInt(priority) || 0 };
    });
    return ok(reminders);
  }

  if (flags.create) {
    const name = esc(typeof flags.create === 'string' ? flags.create : positional.join(' '));
    if (!name) fail('Usage: jeriko remind --create "Buy milk" [--due "tomorrow 9am"] [--list Groceries]');
    const listName = esc(flags.list || 'Reminders');
    let dueScript = '';
    if (flags.due) {
      dueScript = `, due date: date "${esc(flags.due)}"`;
    }
    osascript(`
      tell application "Reminders"
        tell list "${listName}"
          make new reminder with properties {name:"${name}"${dueScript}}
        end tell
      end tell
    `);
    return ok({ created: name, list: listName, due: flags.due || null });
  }

  if (flags.complete) {
    const name = esc(typeof flags.complete === 'string' ? flags.complete : positional.join(' '));
    if (!name) fail('Usage: jeriko remind --complete "Buy milk"');
    osascript(`
      tell application "Reminders"
        set r to first reminder whose name is "${name}" and completed is false
        set completed of r to true
      end tell
    `);
    return ok({ completed: name });
  }

  if (flags.lists) {
    const raw = osascript(`
      tell application "Reminders"
        set output to ""
        repeat with l in lists
          set output to output & name of l & linefeed
        end repeat
        return output
      end tell
    `);
    return ok(raw.split('\n').filter(Boolean));
  }

  fail('Usage: jeriko remind --list [name]|--create <text>|--complete <text>|--lists');
});
