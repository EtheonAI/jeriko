#!/usr/bin/env node
const { parseArgs, ok, fail, readStdin, run, EXIT } = require('../lib/cli');
const { execSync, spawnSync } = require('child_process');
const path = require('path');
const fs = require('fs');
const os = require('os');

// Python scripts for each file type — no npm deps, pure Python
const PYTHON_SCRIPTS = {

  // ==================== PDF ====================
  pdf_read: `
import sys, json
from PyPDF2 import PdfReader
f = sys.argv[1]
pages = sys.argv[2] if len(sys.argv) > 2 else None
r = PdfReader(f)
total = len(r.pages)
if pages:
    parts = pages.split('-')
    start = int(parts[0]) - 1
    end = int(parts[1]) if len(parts) > 1 else start + 1
    rng = range(start, min(end, total))
else:
    rng = range(total)
text = []
for i in rng:
    t = r.pages[i].extract_text() or ''
    text.append(t)
meta = r.metadata
info = {
    'pages': total,
    'read': len(list(rng)),
    'title': str(meta.title or '') if meta else '',
    'author': str(meta.author or '') if meta else '',
    'text': '\\n---\\n'.join(text)
}
print(json.dumps(info))
`,

  pdf_info: `
import sys, json
from PyPDF2 import PdfReader
r = PdfReader(sys.argv[1])
m = r.metadata
print(json.dumps({
    'pages': len(r.pages),
    'title': str(m.title or '') if m else '',
    'author': str(m.author or '') if m else '',
    'creator': str(m.creator or '') if m else '',
    'producer': str(m.producer or '') if m else '',
    'encrypted': r.is_encrypted
}))
`,

  // ==================== EXCEL ====================
  xlsx_read: `
import sys, json
import openpyxl
f = sys.argv[1]
sheet_name = sys.argv[2] if len(sys.argv) > 2 else None
limit = int(sys.argv[3]) if len(sys.argv) > 3 else 100
wb = openpyxl.load_workbook(f, read_only=True, data_only=True)
ws = wb[sheet_name] if sheet_name and sheet_name in wb.sheetnames else wb.active
rows = []
headers = None
for i, row in enumerate(ws.iter_rows(values_only=True)):
    if i == 0:
        headers = [str(c) if c is not None else f'col_{j}' for j, c in enumerate(row)]
        continue
    if i > limit:
        break
    obj = {}
    for j, val in enumerate(row):
        key = headers[j] if j < len(headers) else f'col_{j}'
        obj[key] = str(val) if val is not None else ''
    rows.append(obj)
wb.close()
print(json.dumps({'sheet': ws.title, 'sheets': wb.sheetnames if hasattr(wb, 'sheetnames') else [], 'headers': headers, 'rows': len(rows), 'data': rows}))
`,

  xlsx_sheets: `
import sys, json
import openpyxl
wb = openpyxl.load_workbook(sys.argv[1], read_only=True)
sheets = []
for name in wb.sheetnames:
    ws = wb[name]
    sheets.append({'name': name, 'rows': ws.max_row, 'cols': ws.max_column})
wb.close()
print(json.dumps(sheets))
`,

  xlsx_write: `
import sys, json
import openpyxl
output = sys.argv[1]
data = json.loads(sys.stdin.read())
wb = openpyxl.Workbook()
ws = wb.active
if 'headers' in data:
    ws.append(data['headers'])
for row in data.get('rows', data.get('data', [])):
    if isinstance(row, dict):
        ws.append(list(row.values()))
    elif isinstance(row, list):
        ws.append(row)
wb.save(output)
print(json.dumps({'written': output, 'rows': ws.max_row}))
`,

  // ==================== DOCX ====================
  docx_read: `
import sys, json
from docx import Document
doc = Document(sys.argv[1])
paragraphs = [p.text for p in doc.paragraphs if p.text.strip()]
tables = []
for table in doc.tables:
    rows = []
    for row in table.rows:
        rows.append([cell.text for cell in row.cells])
    tables.append(rows)
props = doc.core_properties
print(json.dumps({
    'paragraphs': len(paragraphs),
    'tables': len(tables),
    'title': props.title or '',
    'author': props.author or '',
    'text': '\\n'.join(paragraphs),
    'table_data': tables
}))
`,

  docx_write: `
import sys, json
from docx import Document
output = sys.argv[1]
data = json.loads(sys.stdin.read())
doc = Document()
if data.get('title'):
    doc.add_heading(data['title'], 0)
for item in data.get('content', []):
    if isinstance(item, str):
        doc.add_paragraph(item)
    elif isinstance(item, dict):
        if item.get('heading'):
            doc.add_heading(item['heading'], item.get('level', 1))
        elif item.get('paragraph'):
            doc.add_paragraph(item['paragraph'])
        elif item.get('table'):
            rows = item['table']
            if rows:
                t = doc.add_table(rows=len(rows), cols=len(rows[0]))
                for i, row in enumerate(rows):
                    for j, val in enumerate(row):
                        t.cell(i, j).text = str(val)
doc.save(output)
print(json.dumps({'written': output}))
`,

  // ==================== CSV ====================
  csv_read: `
import sys, json, csv
f = sys.argv[1]
limit = int(sys.argv[2]) if len(sys.argv) > 2 else 100
with open(f, 'r', encoding='utf-8-sig') as fh:
    sniffer = csv.Sniffer()
    sample = fh.read(4096)
    fh.seek(0)
    try:
        dialect = sniffer.sniff(sample)
    except:
        dialect = csv.excel
    reader = csv.DictReader(fh, dialect=dialect)
    headers = reader.fieldnames or []
    rows = []
    for i, row in enumerate(reader):
        if i >= limit:
            break
        rows.append(dict(row))
print(json.dumps({'headers': headers, 'rows': len(rows), 'data': rows}))
`,

  // ==================== IMAGE ====================
  image_info: `
import sys, json
from PIL import Image
from PIL.ExifTags import TAGS
img = Image.open(sys.argv[1])
info = {
    'width': img.width,
    'height': img.height,
    'format': img.format,
    'mode': img.mode,
    'size_bytes': sys.argv[2] if len(sys.argv) > 2 else 0,
}
exif = img.getexif()
if exif:
    meta = {}
    for tag_id, value in exif.items():
        tag = TAGS.get(tag_id, tag_id)
        try:
            meta[str(tag)] = str(value)
        except:
            pass
    info['exif'] = meta
print(json.dumps(info))
`,

  image_resize: `
import sys, json
from PIL import Image
inp = sys.argv[1]
out = sys.argv[2]
w = int(sys.argv[3])
h = int(sys.argv[4])
img = Image.open(inp)
img = img.resize((w, h), Image.LANCZOS)
img.save(out)
print(json.dumps({'written': out, 'width': w, 'height': h}))
`,

  image_convert: `
import sys, json
from PIL import Image
inp = sys.argv[1]
out = sys.argv[2]
img = Image.open(inp)
if img.mode == 'RGBA' and out.lower().endswith('.jpg'):
    img = img.convert('RGB')
img.save(out)
print(json.dumps({'written': out, 'format': img.format}))
`,
};

function pyExec(script, args = [], stdin = null) {
  const result = spawnSync('python3', ['-c', script, ...args], {
    encoding: 'utf-8',
    timeout: 30000,
    input: stdin || undefined,
    maxBuffer: 10 * 1024 * 1024,
  });

  if (result.error) {
    if (result.error.code === 'ENOENT') fail('python3 not found. Install Python 3.', EXIT.NOT_FOUND);
    throw result.error;
  }

  if (result.status !== 0) {
    const err = result.stderr || '';
    if (err.includes('No module named')) {
      const mod = err.match(/No module named '(\w+)'/)?.[1] || 'unknown';
      fail(`Python module '${mod}' not installed. Run: pip3 install ${mod}`, EXIT.NOT_FOUND);
    }
    fail(err.trim() || `python3 exited with code ${result.status}`);
  }

  try {
    return JSON.parse(result.stdout);
  } catch {
    return result.stdout.trim();
  }
}

function getExt(filePath) {
  return path.extname(filePath).toLowerCase().replace('.', '');
}

// Resolve file path from either positional or flag value
function resolveFile(flags, positional, ...flagNames) {
  for (const name of flagNames) {
    if (typeof flags[name] === 'string') return flags[name];
  }
  return positional[0] || flags.file || null;
}

run(async () => {
  const { flags, positional } = parseArgs(process.argv);
  const file = resolveFile(flags, positional, 'read', 'cat', 'extract', 'info', 'sheets', 'search', 'resize', 'convert');

  // ========== READ ==========
  if (flags.read || flags.cat || flags.extract) {
    if (!file) fail('Usage: jeriko doc --read <file>');
    if (!fs.existsSync(file)) fail(`File not found: ${file}`, EXIT.NOT_FOUND);

    const ext = getExt(file);
    const limit = flags.limit || '100';
    const pages = flags.pages;

    switch (ext) {
      case 'pdf':
        return ok(pyExec(PYTHON_SCRIPTS.pdf_read, pages ? [file, pages] : [file]));
      case 'xlsx': case 'xls':
        return ok(pyExec(PYTHON_SCRIPTS.xlsx_read, [file, flags.sheet || '', limit]));
      case 'docx':
        return ok(pyExec(PYTHON_SCRIPTS.docx_read, [file]));
      case 'csv': case 'tsv':
        return ok(pyExec(PYTHON_SCRIPTS.csv_read, [file, limit]));
      case 'png': case 'jpg': case 'jpeg': case 'gif': case 'bmp': case 'webp': case 'tiff': case 'ico': case 'svg':
        const stat = fs.statSync(file);
        return ok(pyExec(PYTHON_SCRIPTS.image_info, [file, String(stat.size)]));
      case 'txt': case 'md': case 'json': case 'js': case 'py': case 'html': case 'css':
      case 'ts': case 'tsx': case 'jsx': case 'yaml': case 'yml': case 'xml': case 'sh':
      case 'go': case 'rs': case 'rb': case 'java': case 'c': case 'cpp': case 'h':
      case 'sql': case 'env': case 'log': case 'ini': case 'toml': case 'conf':
        // Text files — read directly
        const content = fs.readFileSync(file, 'utf-8');
        return ok({ type: 'text', lines: content.split('\n').length, text: content.slice(0, 50000) });
      default:
        // Try as text, fall back to binary info
        try {
          const content = fs.readFileSync(file, 'utf-8');
          if (/[\x00-\x08\x0E-\x1F]/.test(content.slice(0, 1000))) {
            const stat = fs.statSync(file);
            return ok({ type: 'binary', extension: ext, size: stat.size, message: `Binary file. Use specific flags for supported formats.` });
          }
          return ok({ type: 'text', lines: content.split('\n').length, text: content.slice(0, 50000) });
        } catch {
          const stat = fs.statSync(file);
          return ok({ type: 'binary', extension: ext, size: stat.size });
        }
    }
  }

  // ========== INFO ==========
  if (flags.info) {
    if (!file) fail('Usage: jeriko doc --info <file>');
    if (!fs.existsSync(file)) fail(`File not found: ${file}`, EXIT.NOT_FOUND);

    const ext = getExt(file);
    const stat = fs.statSync(file);
    const base = { path: path.resolve(file), size: stat.size, modified: stat.mtime.toISOString(), extension: ext };

    switch (ext) {
      case 'pdf':
        return ok({ ...base, ...pyExec(PYTHON_SCRIPTS.pdf_info, [file]) });
      case 'xlsx': case 'xls':
        return ok({ ...base, sheets: pyExec(PYTHON_SCRIPTS.xlsx_sheets, [file]) });
      case 'png': case 'jpg': case 'jpeg': case 'gif': case 'bmp': case 'webp': case 'tiff':
        return ok({ ...base, ...pyExec(PYTHON_SCRIPTS.image_info, [file, String(stat.size)]) });
      case 'docx':
        const docInfo = pyExec(PYTHON_SCRIPTS.docx_read, [file]);
        return ok({ ...base, paragraphs: docInfo.paragraphs, tables: docInfo.tables, title: docInfo.title, author: docInfo.author });
      default:
        return ok(base);
    }
  }

  // ========== SHEETS (Excel) ==========
  if (flags.sheets) {
    if (!file) fail('Usage: jeriko doc --sheets <file.xlsx>');
    if (!fs.existsSync(file)) fail(`File not found: ${file}`, EXIT.NOT_FOUND);
    return ok(pyExec(PYTHON_SCRIPTS.xlsx_sheets, [file]));
  }

  // ========== WRITE ==========
  if (flags.write) {
    const output = typeof flags.write === 'string' ? flags.write : positional[0] || flags.file;
    if (!output) fail('Usage: jeriko doc --write <file> (data via stdin JSON)');

    const ext = getExt(output);
    const stdin = await readStdin(5000);
    if (!stdin) fail('Provide data on stdin as JSON');

    switch (ext) {
      case 'xlsx': case 'xls':
        return ok(pyExec(PYTHON_SCRIPTS.xlsx_write, [path.resolve(output)], stdin));
      case 'docx':
        return ok(pyExec(PYTHON_SCRIPTS.docx_write, [path.resolve(output)], stdin));
      case 'csv': case 'tsv': {
        // Write CSV from JSON stdin
        let data;
        try { data = JSON.parse(stdin); } catch { fail('Invalid JSON on stdin'); }
        const sep = ext === 'tsv' ? '\t' : ',';
        const headers = data.headers || Object.keys(data.data?.[0] || data.rows?.[0] || {});
        const rows = data.data || data.rows || [];
        let csv = headers.join(sep) + '\n';
        for (const row of rows) {
          const vals = Array.isArray(row) ? row : headers.map(h => row[h] || '');
          csv += vals.map(v => String(v).includes(sep) ? `"${v}"` : v).join(sep) + '\n';
        }
        fs.writeFileSync(path.resolve(output), csv);
        return ok({ written: path.resolve(output), rows: rows.length });
      }
      default:
        // Text files — write directly
        fs.writeFileSync(path.resolve(output), stdin);
        return ok({ written: path.resolve(output), bytes: Buffer.byteLength(stdin) });
    }
  }

  // ========== IMAGE OPERATIONS ==========
  if (flags.resize) {
    if (!file) fail('Usage: jeriko doc --resize <image> --width N --height N [--output path]');
    if (!fs.existsSync(file)) fail(`File not found: ${file}`, EXIT.NOT_FOUND);
    const w = flags.width; const h = flags.height;
    if (!w || !h) fail('--width and --height required');
    const output = flags.output || flags.o || file;
    return ok(pyExec(PYTHON_SCRIPTS.image_resize, [file, path.resolve(output), w, h]));
  }

  if (flags.convert) {
    if (!file) fail('Usage: jeriko doc --convert <image> --output path.jpg');
    if (!fs.existsSync(file)) fail(`File not found: ${file}`, EXIT.NOT_FOUND);
    const output = flags.output || flags.o;
    if (!output) fail('--output required for conversion');
    return ok(pyExec(PYTHON_SCRIPTS.image_convert, [file, path.resolve(output)]));
  }

  // ========== SEARCH inside documents ==========
  if (flags.search) {
    // --search "term" file.pdf  OR  --search file.pdf --query "term"
    let searchFile = file;
    let query;
    if (typeof flags.search === 'string') {
      // Could be the query or the file — check if it's a file
      if (fs.existsSync(flags.search)) {
        searchFile = flags.search;
        query = positional[0] || flags.query;
      } else {
        query = flags.search;
        searchFile = positional[0] || flags.file;
      }
    } else {
      query = flags.query;
    }
    if (!searchFile) fail('Usage: jeriko doc --search <file> --query "term"');
    if (!fs.existsSync(searchFile)) fail(`File not found: ${searchFile}`, EXIT.NOT_FOUND);
    if (!query) fail('Search term required: --search <file> --query "term"');

    const ext = getExt(searchFile);
    let text = '';

    switch (ext) {
      case 'pdf':
        text = pyExec(PYTHON_SCRIPTS.pdf_read, [searchFile]).text || '';
        break;
      case 'docx':
        text = pyExec(PYTHON_SCRIPTS.docx_read, [searchFile]).text || '';
        break;
      case 'xlsx': case 'xls': {
        const data = pyExec(PYTHON_SCRIPTS.xlsx_read, [searchFile, '', '10000']);
        text = JSON.stringify(data.data);
        break;
      }
      default:
        text = fs.readFileSync(searchFile, 'utf-8');
    }

    const lower = query.toLowerCase();
    const lines = text.split('\n');
    const matches = [];
    for (let i = 0; i < lines.length; i++) {
      if (lines[i].toLowerCase().includes(lower)) {
        matches.push({ line: i + 1, text: lines[i].trim().slice(0, 200) });
      }
    }
    return ok({ query, file: path.resolve(searchFile), matches: matches.length, results: matches.slice(0, 50) });
  }

  fail('Usage: jeriko doc --read <file> [--pages 1-5] [--sheet name] [--limit N]\n       jeriko doc --info <file>\n       jeriko doc --write <file> (stdin JSON)\n       jeriko doc --search <file> --query "term"\n       jeriko doc --resize <image> --width N --height N\n       jeriko doc --convert <image> --output path.jpg\n       jeriko doc --sheets <file.xlsx>\n\nSupported: PDF, XLSX, DOCX, CSV, TSV, PNG, JPG, GIF, BMP, WEBP, TIFF + all text files');
});
