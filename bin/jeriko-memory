#!/usr/bin/env node
const { parseArgs, ok, fail, run, readStdin } = require('../lib/cli');
const path = require('path');
const fs = require('fs');

const DATA_DIR = path.join(__dirname, '..', 'data');
const SESSION_LOG = path.join(DATA_DIR, 'session.jsonl');
const KV_STORE = path.join(DATA_DIR, 'memory.json');

if (!fs.existsSync(DATA_DIR)) fs.mkdirSync(DATA_DIR, { recursive: true });

run(async () => {
  const { flags, positional } = parseArgs(process.argv);

  // --log: append a session entry (used by router automatically)
  if (flags.log) {
    const entry = {
      ts: new Date().toISOString(),
      command: flags.command || null,
      result: null,
      summary: flags.summary || null,
    };
    if (flags.result) {
      try { entry.result = JSON.parse(flags.result); } catch { entry.result = flags.result; }
    }
    const stdin = await readStdin();
    if (stdin) {
      try { entry.result = JSON.parse(stdin); } catch { entry.result = stdin.trim(); }
    }
    fs.appendFileSync(SESSION_LOG, JSON.stringify(entry) + '\n');
    return ok({ logged: true });
  }

  // --clear: clear session log
  if (flags.clear) {
    if (fs.existsSync(SESSION_LOG)) fs.writeFileSync(SESSION_LOG, '');
    return ok({ cleared: true });
  }

  // --set key --value val: store key-value pair
  if (flags.set) {
    const key = typeof flags.set === 'string' ? flags.set : positional[0];
    if (!key) fail('Usage: jeriko memory --set <key> --value <value>');
    let value = flags.value || positional[1] || '';
    if (!value) {
      const stdin = await readStdin();
      if (stdin) value = stdin.trim();
    }
    const store = loadKV();
    store[key] = { value, updatedAt: new Date().toISOString() };
    saveKV(store);
    return ok({ key, stored: true });
  }

  // --get key: retrieve value
  if (flags.get) {
    const key = typeof flags.get === 'string' ? flags.get : positional[0];
    if (!key) fail('Usage: jeriko memory --get <key>');
    const store = loadKV();
    if (!store[key]) fail(`Key "${key}" not found`, 5);
    return ok(store[key]);
  }

  // --keys: list all stored keys
  if (flags.keys) {
    const store = loadKV();
    return ok(Object.keys(store));
  }

  // --search query: search session log
  if (flags.search) {
    const query = (typeof flags.search === 'string' ? flags.search : positional[0] || '').toLowerCase();
    if (!query) fail('Usage: jeriko memory --search <query>');
    const entries = loadSessionLog();
    const matches = entries.filter(e => {
      const text = JSON.stringify(e).toLowerCase();
      return text.includes(query);
    });
    return ok(matches.slice(-50));
  }

  // --context: generate a context block for system prompts
  if (flags.context) {
    const limit = flags.limit ? parseInt(flags.limit) : 10;
    const entries = loadSessionLog().slice(-limit);
    const kv = loadKV();

    let context = '## Recent Session History\n';
    if (entries.length === 0) {
      context += 'No previous commands in this session.\n';
    } else {
      for (const e of entries) {
        const resultStr = e.result
          ? (typeof e.result === 'object' ? JSON.stringify(e.result).slice(0, 200) : String(e.result).slice(0, 200))
          : '(no result)';
        context += `[${e.ts}] ${e.command || 'unknown'} → ${resultStr}\n`;
      }
    }

    const kvKeys = Object.keys(kv);
    if (kvKeys.length > 0) {
      context += '\n## Stored Memory\n';
      for (const key of kvKeys) {
        context += `${key}: ${kv[key].value}\n`;
      }
    }

    if (flags.raw) {
      process.stdout.write(context);
      process.exit(0);
    }
    return ok({ context, entries: entries.length, keys: kvKeys.length });
  }

  // Default: recent session history
  const limit = flags.recent ? parseInt(flags.recent) : 20;
  const entries = loadSessionLog().slice(-limit);
  ok(entries);
});

function loadSessionLog() {
  if (!fs.existsSync(SESSION_LOG)) return [];
  const lines = fs.readFileSync(SESSION_LOG, 'utf-8').split('\n').filter(Boolean);
  return lines.map(line => {
    try { return JSON.parse(line); } catch { return null; }
  }).filter(Boolean);
}

function loadKV() {
  if (!fs.existsSync(KV_STORE)) return {};
  try { return JSON.parse(fs.readFileSync(KV_STORE, 'utf-8')); } catch { return {}; }
}

function saveKV(store) {
  fs.writeFileSync(KV_STORE, JSON.stringify(store, null, 2));
}
