#!/usr/bin/env node
const { parseArgs, ok, fail, run } = require('../lib/cli');
const { captureDesktop, captureDisplay, listDisplays } = require('../tools/screenshot');

run(async () => {
  const { flags } = parseArgs(process.argv);

  if (flags.list) {
    return ok(await listDisplays());
  }

  let result;
  if (flags.display) {
    result = await captureDisplay(flags.display);
  } else {
    result = await captureDesktop();
  }

  // Emit marker to stderr for telegram.js extraction
  process.stderr.write(`SCREENSHOT:${result.path}\n`);
  ok(result);
});
