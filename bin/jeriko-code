#!/usr/bin/env node
const { parseArgs, ok, fail, readStdin, run, EXIT } = require('../lib/cli');
const { spawn } = require('child_process');

// Sensitive vars stripped from child process env
const STRIP = [
  'NODE_AUTH_SECRET', 'TELEGRAM_BOT_TOKEN', 'OPENAI_API_KEY',
  'IMAP_PASSWORD', 'ANTHROPIC_API_KEY', 'GEMINI_API_KEY',
  'STRIPE_SECRET_KEY', 'X_BEARER_TOKEN', 'X_CLIENT_SECRET',
  'TWILIO_AUTH_TOKEN',
];

run(async () => {
  const { flags, positional } = parseArgs(process.argv);

  // Determine language and code
  let language, code;

  if (flags.python) {
    language = 'python';
    code = typeof flags.python === 'string' ? flags.python : null;
  } else if (flags.node || flags.js) {
    language = 'node';
    code = typeof (flags.node || flags.js) === 'string' ? (flags.node || flags.js) : null;
  } else if (flags.bash || flags.sh) {
    language = 'bash';
    code = typeof (flags.bash || flags.sh) === 'string' ? (flags.bash || flags.sh) : null;
  }

  if (!code) code = positional.join(' ') || null;
  if (!code) {
    const stdin = await readStdin();
    if (stdin) code = stdin.trim();
  }

  if (!code) fail('Usage: jeriko code --python "print(42)"\n       jeriko code --node "console.log(42)"\n       echo "print(1+1)" | jeriko code --python');
  if (!language) language = 'python';

  const timeout = flags.timeout ? parseInt(flags.timeout) : 30000;

  // Resolve command
  const cmds = {
    python: ['python3', ['-c', code]],
    node:   [process.execPath, ['-e', code]],
    bash:   ['bash', ['-c', code]],
  };

  const entry = cmds[language];
  if (!entry) fail(`Unsupported language: ${language}`);

  // Build safe env (strip secrets)
  const env = { ...process.env };
  for (const k of STRIP) delete env[k];

  // Spawn and collect output
  const result = await new Promise((resolve, reject) => {
    const proc = spawn(entry[0], entry[1], {
      env, stdio: ['ignore', 'pipe', 'pipe'], timeout,
    });

    const out = [], err = [];
    proc.stdout.on('data', (d) => out.push(d.toString()));
    proc.stderr.on('data', (d) => err.push(d.toString()));
    proc.on('close', (exitCode) => resolve({
      language,
      output: out.join('').slice(0, 10000),
      stderr: err.join('').slice(0, 5000),
      exitCode,
    }));
    proc.on('error', (e) => reject(new Error(`${language}: ${e.message}`)));
  });

  if (result.exitCode === null) fail(`Timed out after ${timeout}ms`, EXIT.TIMEOUT);

  ok(result);
});
