#!/usr/bin/env node
const { parseArgs, ok, fail, run, EXIT } = require('../lib/cli');
const { execSync, spawn } = require('child_process');

run(async () => {
  const { flags, positional } = parseArgs(process.argv);

  // --list: top processes by CPU
  if (flags.list || Object.keys(flags).length === 0) {
    const limit = parseInt(flags.limit) || 15;
    const raw = execSync(`ps aux | head -${limit + 1}`, { encoding: 'utf-8', timeout: 5000 });
    const lines = raw.trim().split('\n');
    const header = lines[0];
    const procs = lines.slice(1).map(line => {
      const parts = line.trim().split(/\s+/);
      return {
        user: parts[0],
        pid: parseInt(parts[1]),
        cpu: parseFloat(parts[2]),
        mem: parseFloat(parts[3]),
        command: parts.slice(10).join(' ').slice(0, 100),
      };
    });
    return ok(procs);
  }

  // --kill <pid>
  if (flags.kill) {
    const pid = parseInt(typeof flags.kill === 'string' ? flags.kill : positional[0]);
    if (!pid || isNaN(pid)) fail('Usage: jeriko proc --kill <pid>');
    const signal = flags.signal || 'TERM';
    try {
      process.kill(pid, signal === '9' || signal === 'KILL' ? 'SIGKILL' : 'SIGTERM');
      return ok({ killed: pid, signal });
    } catch (e) {
      if (e.code === 'ESRCH') fail(`No process with PID ${pid}`, EXIT.NOT_FOUND);
      if (e.code === 'EPERM') fail(`Permission denied to kill PID ${pid}`, EXIT.AUTH);
      throw e;
    }
  }

  // --kill-name <name>
  if (flags['kill-name']) {
    const name = typeof flags['kill-name'] === 'string' ? flags['kill-name'] : positional[0];
    if (!name) fail('Usage: jeriko proc --kill-name <name>');
    try {
      execSync(`pkill -f "${name.replace(/"/g, '\\"')}"`, { encoding: 'utf-8', timeout: 5000 });
      return ok({ killed: name });
    } catch (e) {
      if (e.status === 1) fail(`No processes matching "${name}"`, EXIT.NOT_FOUND);
      throw e;
    }
  }

  // --start <command>: run in background, return PID
  if (flags.start) {
    const cmd = typeof flags.start === 'string' ? flags.start : positional.join(' ');
    if (!cmd) fail('Usage: jeriko proc --start <command>');
    const child = spawn('bash', ['-c', cmd], {
      detached: true,
      stdio: 'ignore',
    });
    child.unref();
    return ok({ pid: child.pid, command: cmd, background: true });
  }

  // --find <name>: find processes by name
  if (flags.find) {
    const name = typeof flags.find === 'string' ? flags.find : positional[0];
    if (!name) fail('Usage: jeriko proc --find <name>');
    try {
      const raw = execSync(`pgrep -fl "${name.replace(/"/g, '\\"')}"`, { encoding: 'utf-8', timeout: 5000 });
      const procs = raw.trim().split('\n').filter(Boolean).map(line => {
        const [pid, ...rest] = line.trim().split(/\s+/);
        return { pid: parseInt(pid), command: rest.join(' ') };
      });
      return ok(procs);
    } catch {
      return ok([]);
    }
  }

  fail('Usage: jeriko proc --list|--kill <pid>|--kill-name <name>|--start <cmd>|--find <name>');
});
