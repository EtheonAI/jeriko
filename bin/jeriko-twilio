#!/usr/bin/env node
// ============================================================
// jeriko-twilio — Full Twilio Voice + SMS/MMS CLI built on Twilio REST API
// Standalone CLI: jeriko twilio <command> [flags]
// ============================================================
const { parseArgs, ok, fail, run, EXIT } = require('../lib/cli');
const readline = require('readline');
const path = require('path');
const fs = require('fs');

const BASE = 'https://api.twilio.com/2010-04-01';
const ENV_PATH = path.join(__dirname, '..', '.env');

// Colors
const C = {
  cyan: '\x1b[36m', bold: '\x1b[1m', dim: '\x1b[2m',
  green: '\x1b[32m', red: '\x1b[31m', yellow: '\x1b[33m',
  reset: '\x1b[0m',
};

// ---- Credential helpers ----

function getCreds() {
  const sid = process.env.TWILIO_ACCOUNT_SID;
  const token = process.env.TWILIO_AUTH_TOKEN;
  const phone = process.env.TWILIO_PHONE_NUMBER;
  return { sid, token, phone };
}

function requireCreds() {
  const { sid, token, phone } = getCreds();
  if (!sid || !token) {
    fail('TWILIO_ACCOUNT_SID / TWILIO_AUTH_TOKEN not set. Run: jeriko twilio init', EXIT.AUTH);
  }
  return { sid, token, phone };
}

// ---- .env helpers ----

function readEnv() {
  if (!fs.existsSync(ENV_PATH)) return {};
  const lines = fs.readFileSync(ENV_PATH, 'utf-8').split('\n');
  const env = {};
  for (const line of lines) {
    const m = line.match(/^\s*([A-Z_][A-Z0-9_]*)\s*=\s*(.*)/);
    if (m) env[m[1]] = m[2].replace(/^["']|["']$/g, '');
  }
  return env;
}

function writeEnvKey(key, value) {
  let content = fs.existsSync(ENV_PATH) ? fs.readFileSync(ENV_PATH, 'utf-8') : '';
  const regex = new RegExp(`^\\s*#?\\s*${key}\\s*=.*$`, 'm');
  const line = `${key}=${value}`;
  if (regex.test(content)) {
    content = content.replace(regex, line);
    fs.writeFileSync(ENV_PATH, content);
  } else {
    fs.appendFileSync(ENV_PATH, (content && !content.endsWith('\n') ? '\n' : '') + line + '\n');
  }
  process.env[key] = value;
}

function ask(rl, question, defaultValue) {
  const defLabel = defaultValue !== undefined ? ` ${C.dim}(${defaultValue})${C.reset}` : '';
  return new Promise((resolve) => {
    rl.question(`  ${C.cyan}?${C.reset} ${question}${defLabel} `, (answer) => {
      resolve(answer.trim() || (defaultValue !== undefined ? String(defaultValue) : ''));
    });
  });
}

function maskKey(key) {
  if (!key || key.length < 10) return '***';
  return key.slice(0, 8) + '...' + key.slice(-4);
}

// ---- HTTP helper ----

async function twilio(method, urlPath, params = {}) {
  const { sid, token } = requireCreds();
  const auth = Buffer.from(`${sid}:${token}`).toString('base64');
  let url = `${BASE}/Accounts/${sid}${urlPath}.json`;
  const opts = {
    method,
    headers: { 'Authorization': `Basic ${auth}` },
  };

  if (method === 'GET') {
    const qs = new URLSearchParams(params).toString();
    if (qs) url += '?' + qs;
  } else if (method === 'DELETE') {
    // no body
  } else if (Object.keys(params).length) {
    opts.headers['Content-Type'] = 'application/x-www-form-urlencoded';
    opts.body = new URLSearchParams(params).toString();
  }

  const res = await fetch(url, opts);
  if (res.status === 204) return {};
  const text = await res.text();
  let data;
  try { data = JSON.parse(text); } catch { data = { raw: text }; }
  if (!res.ok) {
    const msg = data.message || data.more_info || JSON.stringify(data);
    const code = res.status === 401 || res.status === 403 ? EXIT.AUTH
      : res.status === 404 ? EXIT.NOT_FOUND : EXIT.GENERAL;
    fail(`Twilio ${res.status}: ${msg}`, code);
  }
  return data;
}

// ---- Command router ----

run(async () => {
  const args = process.argv.slice(2);
  const command = args[0];
  const { flags, positional } = parseArgs(['', '', ...args.slice(1)]);

  if (!command) {
    return ok({
      usage: 'jeriko twilio <command> [flags]',
      commands: {
        init: 'interactive setup wizard',
        call: 'make a voice call — +number --say "text" | --play <url> | --url <twiml>',
        calls: 'list recent calls [--status X] [--to +X] [--from +X] [--limit N]',
        'call-status': 'get call details — <CallSid>',
        hangup: 'end an active call — <CallSid>',
        delete: 'delete a call record — <CallSid>',
        sms: 'send SMS/MMS — +number "text" [--media <url>]',
        messages: 'list messages [--to +X] [--from +X] [--limit N]',
        'message-status': 'get message details — <MessageSid>',
        'delete-message': 'delete a message record — <MessageSid>',
        recordings: 'list recordings [--call <CallSid>] [--limit N]',
        recording: 'get or delete a recording — <RecordingSid> [--delete]',
        account: 'account info (name, status, balance)',
        numbers: 'list owned phone numbers [--limit N]',
      },
    });
  }

  // ===================== INIT =====================
  if (command === 'init') {
    const w = (s) => process.stderr.write(s);
    w('\n');
    w(`  ${C.bold}${C.cyan}Twilio Setup${C.reset}\n`);
    w(`  ${C.dim}Voice calls, SMS/MMS, recordings, phone numbers${C.reset}\n`);
    w('\n');

    // Non-interactive: jeriko twilio init --sid ACxxx --token xxx --phone +1xxx
    if (flags.sid || flags.token) {
      if (flags.sid) writeEnvKey('TWILIO_ACCOUNT_SID', flags.sid);
      if (flags.token) writeEnvKey('TWILIO_AUTH_TOKEN', flags.token);
      if (flags.phone) writeEnvKey('TWILIO_PHONE_NUMBER', flags.phone);

      // Verify
      if (flags.sid && flags.token) {
        try {
          const auth = Buffer.from(`${flags.sid}:${flags.token}`).toString('base64');
          const res = await fetch(`${BASE}/Accounts/${flags.sid}.json`, {
            headers: { 'Authorization': `Basic ${auth}` },
          });
          if (!res.ok) throw new Error(`HTTP ${res.status}`);
          w(`  ${C.green}[ok]${C.reset} Twilio credentials verified and saved\n\n`);
        } catch (e) {
          w(`  ${C.red}[!!]${C.reset} Credentials saved but verification failed: ${e.message}\n\n`);
        }
      }
      return ok({ status: 'configured' });
    }

    const rl = readline.createInterface({
      input: process.stdin,
      output: process.stderr,
      terminal: true,
    });

    const env = readEnv();

    // Step 1: Account SID + Auth Token
    w(`  ${C.bold}Step 1: Credentials${C.reset}\n`);
    w(`  ${C.dim}Get them at: https://console.twilio.com${C.reset}\n\n`);

    let sid;
    if (env.TWILIO_ACCOUNT_SID) {
      w(`  ${C.dim}Current SID: ${maskKey(env.TWILIO_ACCOUNT_SID)}${C.reset}\n`);
      const keep = await ask(rl, 'Keep existing Account SID? (Y/n)', 'Y');
      sid = keep.toLowerCase() === 'n' ? await ask(rl, 'Account SID (AC...):') : env.TWILIO_ACCOUNT_SID;
    } else {
      sid = await ask(rl, 'Account SID (AC...):');
    }

    let token;
    if (env.TWILIO_AUTH_TOKEN) {
      w(`  ${C.dim}Current Token: ${maskKey(env.TWILIO_AUTH_TOKEN)}${C.reset}\n`);
      const keep = await ask(rl, 'Keep existing Auth Token? (Y/n)', 'Y');
      token = keep.toLowerCase() === 'n' ? await ask(rl, 'Auth Token:') : env.TWILIO_AUTH_TOKEN;
    } else {
      token = await ask(rl, 'Auth Token:');
    }

    if (!sid || !token) {
      w(`\n  ${C.dim}Skipped — credentials not provided${C.reset}\n\n`);
      rl.close();
      return ok({ status: 'skipped' });
    }

    // Verify credentials
    w('\n');
    const frames = ['.  ', '.. ', '...', '   '];
    let fi = 0;
    const spin = setInterval(() => {
      process.stderr.write(`\r  ${C.dim}Verifying${frames[fi++ % frames.length]}${C.reset}`);
    }, 200);

    let verified = false;
    let accountName = '';
    try {
      const auth = Buffer.from(`${sid}:${token}`).toString('base64');
      const res = await fetch(`${BASE}/Accounts/${sid}.json`, {
        headers: { 'Authorization': `Basic ${auth}` },
      });
      clearInterval(spin);
      if (res.ok) {
        const data = await res.json();
        verified = true;
        accountName = data.friendly_name || '';
        process.stderr.write(`\r  ${C.green}[ok]${C.reset} Account verified: ${accountName}${' '.repeat(20)}\n`);
      } else {
        const body = await res.json().catch(() => ({}));
        process.stderr.write(`\r  ${C.red}[!!]${C.reset} Verification failed: ${body.message || `HTTP ${res.status}`}${' '.repeat(20)}\n`);
      }
    } catch (e) {
      clearInterval(spin);
      process.stderr.write(`\r  ${C.red}[!!]${C.reset} Verification failed: ${e.message}${' '.repeat(20)}\n`);
    }

    writeEnvKey('TWILIO_ACCOUNT_SID', sid);
    w(`  ${C.green}[ok]${C.reset} TWILIO_ACCOUNT_SID saved to .env\n`);
    writeEnvKey('TWILIO_AUTH_TOKEN', token);
    w(`  ${C.green}[ok]${C.reset} TWILIO_AUTH_TOKEN saved to .env\n`);

    // Step 2: Phone Number
    w('\n');
    w(`  ${C.bold}Step 2: Twilio Phone Number${C.reset}\n`);
    w(`  ${C.dim}E.164 format: +1234567890${C.reset}\n\n`);

    let phone;
    if (env.TWILIO_PHONE_NUMBER) {
      w(`  ${C.dim}Current: ${env.TWILIO_PHONE_NUMBER}${C.reset}\n`);
      const keep = await ask(rl, 'Keep existing number? (Y/n)', 'Y');
      phone = keep.toLowerCase() === 'n' ? await ask(rl, 'Twilio Phone Number (+...):') : env.TWILIO_PHONE_NUMBER;
    } else {
      phone = await ask(rl, 'Twilio Phone Number (+...):');
    }

    if (phone) {
      // Verify the number belongs to this account and is voice-capable
      if (verified) {
        try {
          const auth = Buffer.from(`${sid}:${token}`).toString('base64');
          const qs = new URLSearchParams({ PhoneNumber: phone }).toString();
          const res = await fetch(`${BASE}/Accounts/${sid}/IncomingPhoneNumbers.json?${qs}`, {
            headers: { 'Authorization': `Basic ${auth}` },
          });
          if (res.ok) {
            const data = await res.json();
            if (data.incoming_phone_numbers && data.incoming_phone_numbers.length > 0) {
              const num = data.incoming_phone_numbers[0];
              const voiceCapable = num.capabilities?.voice;
              if (voiceCapable) {
                w(`  ${C.green}[ok]${C.reset} Number verified — voice capable\n`);
              } else {
                w(`  ${C.yellow}[!]${C.reset} Number found but voice may not be enabled\n`);
              }
            } else {
              w(`  ${C.yellow}[!]${C.reset} Number not found on this account — saving anyway\n`);
            }
          }
        } catch {
          // non-fatal
        }
      }
      writeEnvKey('TWILIO_PHONE_NUMBER', phone);
      w(`  ${C.green}[ok]${C.reset} TWILIO_PHONE_NUMBER saved to .env\n`);
    }

    // Done
    w('\n');
    w(`  ${C.bold}Next steps:${C.reset}\n`);
    w(`    ${C.cyan}jeriko twilio account${C.reset}              ${C.dim}# account info${C.reset}\n`);
    w(`    ${C.cyan}jeriko twilio numbers${C.reset}              ${C.dim}# list numbers${C.reset}\n`);
    w(`    ${C.cyan}jeriko twilio call +1... --say "Hi"${C.reset}    ${C.dim}# make a call${C.reset}\n`);
    w(`    ${C.cyan}jeriko twilio sms +1... "Hello"${C.reset}        ${C.dim}# send SMS${C.reset}\n`);
    w('\n');

    rl.close();
    return ok({ status: 'configured', verified, account: accountName });
  }

  // ===================== CALL (make a call) =====================
  if (command === 'call') {
    const { phone } = requireCreds();
    const to = positional[0];
    if (!to) fail('Usage: jeriko twilio call +1234567890 --say "Hello" | --play <url> | --url <twiml>');
    if (!phone) fail('TWILIO_PHONE_NUMBER not set. Run: jeriko twilio init', EXIT.AUTH);

    const params = { To: to, From: phone };

    if (flags.say) {
      const voice = flags.voice || 'alice';
      const lang = flags.lang || 'en-US';
      params.Twiml = `<Response><Say voice="${voice}" language="${lang}">${escapeXml(flags.say)}</Say></Response>`;
    } else if (flags.play) {
      params.Twiml = `<Response><Play>${escapeXml(flags.play)}</Play></Response>`;
    } else if (flags.url) {
      params.Url = flags.url;
    } else {
      fail('Must specify --say "text", --play <url>, or --url <twiml-url>');
    }

    if (flags.record) params.Record = 'true';
    if (flags['status-callback']) params.StatusCallback = flags['status-callback'];
    if (flags.timeout) params.Timeout = flags.timeout;

    const data = await twilio('POST', '/Calls', params);
    return ok({
      sid: data.sid,
      to: data.to,
      from: data.from,
      status: data.status,
      direction: data.direction,
      price: data.price,
      uri: data.uri,
    });
  }

  // ===================== CALLS (list) =====================
  if (command === 'calls') {
    const params = { PageSize: flags.limit || '20' };
    if (flags.status) params.Status = flags.status;
    if (flags.to) params.To = flags.to;
    if (flags.from) params.From = flags.from;
    if (flags['start-time']) params['StartTime>'] = flags['start-time'];

    const data = await twilio('GET', '/Calls', params);
    const calls = data.calls || [];
    return ok(calls.map(c => ({
      sid: c.sid,
      to: c.to,
      from: c.from,
      status: c.status,
      direction: c.direction,
      duration: c.duration,
      price: c.price,
      start_time: c.start_time,
      end_time: c.end_time,
    })));
  }

  // ===================== CALL-STATUS (get call details) =====================
  if (command === 'call-status') {
    const sid = positional[0] || flags.sid;
    if (!sid) fail('Usage: jeriko twilio call-status <CallSid>');
    const data = await twilio('GET', `/Calls/${sid}`);
    return ok({
      sid: data.sid,
      to: data.to,
      from: data.from,
      status: data.status,
      direction: data.direction,
      duration: data.duration,
      price: data.price,
      price_unit: data.price_unit,
      start_time: data.start_time,
      end_time: data.end_time,
      answered_by: data.answered_by,
      caller_name: data.caller_name,
      uri: data.uri,
    });
  }

  // ===================== HANGUP (end active call) =====================
  if (command === 'hangup') {
    const sid = positional[0] || flags.sid;
    if (!sid) fail('Usage: jeriko twilio hangup <CallSid>');
    const data = await twilio('POST', `/Calls/${sid}`, { Status: 'completed' });
    return ok({ sid: data.sid, status: data.status, ended: true });
  }

  // ===================== DELETE (delete call record) =====================
  if (command === 'delete') {
    const sid = positional[0] || flags.sid;
    if (!sid) fail('Usage: jeriko twilio delete <CallSid>');
    await twilio('DELETE', `/Calls/${sid}`);
    return ok({ sid, deleted: true });
  }

  // ===================== SMS (send) =====================
  if (command === 'sms') {
    const { phone } = requireCreds();
    const to = positional[0];
    const body = positional[1] || flags.message || flags.body;
    if (!to) fail('Usage: jeriko twilio sms +1234567890 "Hello" [--media <url>]');
    if (!phone) fail('TWILIO_PHONE_NUMBER not set. Run: jeriko twilio init', EXIT.AUTH);
    if (!body && !flags.media) fail('Must specify message text or --media <url>');

    const params = { To: to, From: phone };
    if (body) params.Body = body;
    if (flags.media) params.MediaUrl = flags.media;
    if (flags['status-callback']) params.StatusCallback = flags['status-callback'];

    const data = await twilio('POST', '/Messages', params);
    return ok({
      sid: data.sid,
      to: data.to,
      from: data.from,
      status: data.status,
      body: data.body,
      num_media: data.num_media,
      price: data.price,
      date_sent: data.date_sent,
      uri: data.uri,
    });
  }

  // ===================== MESSAGES (list) =====================
  if (command === 'messages') {
    const params = { PageSize: flags.limit || '20' };
    if (flags.to) params.To = flags.to;
    if (flags.from) params.From = flags.from;
    if (flags['date-sent']) params['DateSent>'] = flags['date-sent'];

    const data = await twilio('GET', '/Messages', params);
    const messages = data.messages || [];
    return ok(messages.map(m => ({
      sid: m.sid,
      to: m.to,
      from: m.from,
      status: m.status,
      direction: m.direction,
      body: m.body,
      num_media: m.num_media,
      price: m.price,
      date_sent: m.date_sent,
    })));
  }

  // ===================== MESSAGE-STATUS (get details) =====================
  if (command === 'message-status') {
    const sid = positional[0] || flags.sid;
    if (!sid) fail('Usage: jeriko twilio message-status <MessageSid>');
    const data = await twilio('GET', `/Messages/${sid}`);
    return ok({
      sid: data.sid,
      to: data.to,
      from: data.from,
      status: data.status,
      direction: data.direction,
      body: data.body,
      num_media: data.num_media,
      num_segments: data.num_segments,
      price: data.price,
      price_unit: data.price_unit,
      error_code: data.error_code,
      error_message: data.error_message,
      date_sent: data.date_sent,
      date_created: data.date_created,
      uri: data.uri,
    });
  }

  // ===================== DELETE-MESSAGE =====================
  if (command === 'delete-message') {
    const sid = positional[0] || flags.sid;
    if (!sid) fail('Usage: jeriko twilio delete-message <MessageSid>');
    await twilio('DELETE', `/Messages/${sid}`);
    return ok({ sid, deleted: true });
  }

  // ===================== RECORDINGS (list) =====================
  if (command === 'recordings') {
    const params = { PageSize: flags.limit || '20' };
    if (flags.call) params.CallSid = flags.call;

    const data = await twilio('GET', '/Recordings', params);
    const recordings = data.recordings || [];
    return ok(recordings.map(r => ({
      sid: r.sid,
      call_sid: r.call_sid,
      duration: r.duration,
      channels: r.channels,
      status: r.status,
      price: r.price,
      date_created: r.date_created,
      uri: r.uri,
    })));
  }

  // ===================== RECORDING (get/delete) =====================
  if (command === 'recording') {
    const sid = positional[0] || flags.sid;
    if (!sid) fail('Usage: jeriko twilio recording <RecordingSid> [--delete]');

    if (flags.delete) {
      await twilio('DELETE', `/Recordings/${sid}`);
      return ok({ sid, deleted: true });
    }

    const data = await twilio('GET', `/Recordings/${sid}`);
    return ok({
      sid: data.sid,
      call_sid: data.call_sid,
      duration: data.duration,
      channels: data.channels,
      status: data.status,
      price: data.price,
      price_unit: data.price_unit,
      date_created: data.date_created,
      uri: data.uri,
    });
  }

  // ===================== ACCOUNT =====================
  if (command === 'account') {
    const { sid } = requireCreds();
    const data = await twilio('GET', '');
    // Fetch balance separately
    let balance = null;
    try {
      const { sid: s, token: t } = requireCreds();
      const auth = Buffer.from(`${s}:${t}`).toString('base64');
      const bRes = await fetch(`${BASE}/Accounts/${s}/Balance.json`, {
        headers: { 'Authorization': `Basic ${auth}` },
      });
      if (bRes.ok) balance = await bRes.json();
    } catch { /* non-fatal */ }

    return ok({
      sid: data.sid,
      friendly_name: data.friendly_name,
      status: data.status,
      type: data.type,
      date_created: data.date_created,
      balance: balance ? `${balance.balance} ${balance.currency}` : null,
    });
  }

  // ===================== NUMBERS (list) =====================
  if (command === 'numbers') {
    const params = { PageSize: flags.limit || '20' };
    const data = await twilio('GET', '/IncomingPhoneNumbers', params);
    const numbers = data.incoming_phone_numbers || [];
    return ok(numbers.map(n => ({
      sid: n.sid,
      phone_number: n.phone_number,
      friendly_name: n.friendly_name,
      capabilities: n.capabilities,
      date_created: n.date_created,
      status: n.status,
    })));
  }

  fail(`Unknown command: twilio ${command}\nRun "jeriko twilio" for usage.`);
});

// ---- Utilities ----

function escapeXml(str) {
  return String(str)
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&apos;');
}
