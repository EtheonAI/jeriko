#!/usr/bin/env node
const { parseArgs, ok, fail, run } = require('../lib/cli');
const { execSync } = require('child_process');
const path = require('path');
const fs = require('fs');

const MEDIA_DIR = path.join(__dirname, '..', 'screenshots');
if (!fs.existsSync(MEDIA_DIR)) fs.mkdirSync(MEDIA_DIR, { recursive: true });

run(async () => {
  const { flags, positional } = parseArgs(process.argv);

  if (flags.record) {
    const duration = typeof flags.record === 'string' ? flags.record : '5';
    const filename = `audio-${Date.now()}.m4a`;
    const filepath = path.join(MEDIA_DIR, filename);
    try { execSync('which ffmpeg', { stdio: 'ignore' }); } catch {
      fail('ffmpeg not installed. Run: brew install ffmpeg');
    }
    try {
      execSync(`ffmpeg -f avfoundation -i ":0" -t ${duration} -y "${filepath}" 2>/dev/null`, {
        timeout: (parseInt(duration) + 10) * 1000,
      });
    } catch (e) {
      fail(`Recording failed: ${e.message}`);
    }
    process.stderr.write(`FILE:${filepath}\n`);
    return ok({ path: filepath, filename, duration: `${duration}s` });
  }

  if (flags.say) {
    const text = typeof flags.say === 'string' ? flags.say : positional.join(' ');
    if (!text) fail('Usage: jeriko audio --say "Hello world" [--voice Alex]');
    // Use -- to prevent flag injection, pipe text via stdin to avoid shell injection
    const voiceArgs = flags.voice ? ['-v', flags.voice] : [];
    require('child_process').execFileSync('say', [...voiceArgs, '--', text], { timeout: 30000 });
    return ok({ spoken: text });
  }

  if (flags.volume !== undefined) {
    const vol = typeof flags.volume === 'string' ? flags.volume : positional[0];
    if (vol === undefined) {
      // Get current volume
      const current = execSync('osascript -e "output volume of (get volume settings)"', { encoding: 'utf-8' }).trim();
      return ok({ volume: parseInt(current) });
    }
    execSync(`osascript -e 'set volume output volume ${vol}'`, { timeout: 5000 });
    return ok({ volume: parseInt(vol) });
  }

  if (flags.mute) {
    execSync('osascript -e "set volume output muted true"', { timeout: 5000 });
    return ok({ muted: true });
  }

  if (flags.unmute) {
    execSync('osascript -e "set volume output muted false"', { timeout: 5000 });
    return ok({ muted: false });
  }

  fail('Usage: jeriko audio --record [seconds]|--say <text>|--volume [0-100]|--mute|--unmute');
});
