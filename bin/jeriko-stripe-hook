#!/usr/bin/env node
// Backward-compat shim — delegates to: jeriko stripe hook
// The hook logic now lives inside jeriko-stripe (resource: 'hook')
const { execSync } = require('child_process');
const path = require('path');

try {
  execSync(`node ${path.join(__dirname, 'jeriko')} stripe hook`, {
    env: process.env,
    stdio: 'inherit',
    timeout: 15000,
  });
} catch (e) {
  process.exit(e.status || 1);
}
