#!/usr/bin/env node
// ============================================================
// jeriko-gdrive — Full Google Drive CLI built on Drive REST API v3
// Standalone CLI: jeriko gdrive <command> [flags]
// ============================================================
const { parseArgs, ok, fail, run, EXIT } = require('../lib/cli');
const https = require('https');
const readline = require('readline');
const path = require('path');
const fs = require('fs');

const ENV_PATH = path.join(__dirname, '..', '.env');

// Colors
const C = {
  cyan: '\x1b[36m', bold: '\x1b[1m', dim: '\x1b[2m',
  green: '\x1b[32m', red: '\x1b[31m', yellow: '\x1b[33m',
  reset: '\x1b[0m',
};

// ---- .env helpers ----

function readEnv() {
  if (!fs.existsSync(ENV_PATH)) return {};
  const lines = fs.readFileSync(ENV_PATH, 'utf-8').split('\n');
  const env = {};
  for (const line of lines) {
    const m = line.match(/^\s*([A-Z_][A-Z0-9_]*)\s*=\s*(.*)/);
    if (m) env[m[1]] = m[2].replace(/^["']|["']$/g, '');
  }
  return env;
}

function writeEnvKey(key, value) {
  let content = fs.existsSync(ENV_PATH) ? fs.readFileSync(ENV_PATH, 'utf-8') : '';
  const regex = new RegExp(`^\\s*#?\\s*${key}\\s*=.*$`, 'm');
  const line = `${key}=${value}`;
  if (regex.test(content)) {
    content = content.replace(regex, line);
    fs.writeFileSync(ENV_PATH, content);
  } else {
    fs.appendFileSync(ENV_PATH, (content && !content.endsWith('\n') ? '\n' : '') + line + '\n');
  }
  // Also set in current process
  process.env[key] = value;
}

function ask(rl, question, defaultValue) {
  const defLabel = defaultValue !== undefined ? ` ${C.dim}(${defaultValue})${C.reset}` : '';
  return new Promise((resolve) => {
    rl.question(`  ${C.cyan}?${C.reset} ${question}${defLabel} `, (answer) => {
      resolve(answer.trim() || (defaultValue !== undefined ? String(defaultValue) : ''));
    });
  });
}

function maskKey(key) {
  if (!key || key.length < 10) return '***';
  return key.slice(0, 8) + '...' + key.slice(-4);
}

// ---- MIME type maps ----

const TYPE_QUERY_MAP = {
  document: "mimeType = 'application/vnd.google-apps.document'",
  spreadsheet: "mimeType = 'application/vnd.google-apps.spreadsheet'",
  presentation: "mimeType = 'application/vnd.google-apps.presentation'",
  pdf: "mimeType = 'application/pdf'",
  image: "mimeType contains 'image/'",
  folder: "mimeType = 'application/vnd.google-apps.folder'",
};

const EXPORT_MIME_MAP = {
  pdf: 'application/pdf',
  docx: 'application/vnd.openxmlformats-officedocument.wordprocessingml.document',
  xlsx: 'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet',
  pptx: 'application/vnd.openxmlformats-officedocument.presentationml.presentation',
  txt: 'text/plain',
  csv: 'text/csv',
  html: 'text/html',
  rtf: 'application/rtf',
  odt: 'application/vnd.oasis.opendocument.text',
  tsv: 'text/tab-separated-values',
  svg: 'image/svg+xml',
  jpg: 'image/jpeg',
  png: 'image/png',
};

const GOOGLE_MIME_TYPES = [
  'application/vnd.google-apps.document',
  'application/vnd.google-apps.spreadsheet',
  'application/vnd.google-apps.presentation',
  'application/vnd.google-apps.drawing',
  'application/vnd.google-apps.form',
  'application/vnd.google-apps.script',
];

// ---- HTTP helpers ----

function httpsRequest(options, body) {
  return new Promise((resolve, reject) => {
    const req = https.request(options, (res) => {
      const chunks = [];
      res.on('data', (chunk) => chunks.push(chunk));
      res.on('end', () => {
        const buf = Buffer.concat(chunks);
        resolve({ statusCode: res.statusCode, headers: res.headers, body: buf });
      });
    });
    req.on('error', (err) => reject(err));
    if (body) req.write(body);
    req.end();
  });
}

function httpsPost(hostname, urlPath, formData) {
  const body = Object.entries(formData)
    .map(([k, v]) => `${encodeURIComponent(k)}=${encodeURIComponent(v)}`)
    .join('&');
  return httpsRequest({
    hostname,
    path: urlPath,
    method: 'POST',
    headers: {
      'Content-Type': 'application/x-www-form-urlencoded',
      'Content-Length': Buffer.byteLength(body),
    },
  }, body);
}

// ---- Token management ----

let _cachedAccessToken = null;

async function getAccessToken() {
  if (_cachedAccessToken) return _cachedAccessToken;

  const clientId = process.env.GOOGLE_DRIVE_CLIENT_ID;
  const clientSecret = process.env.GOOGLE_DRIVE_CLIENT_SECRET;
  const refreshToken = process.env.GOOGLE_DRIVE_REFRESH_TOKEN;
  if (!clientId || !clientSecret || !refreshToken) {
    fail('Google Drive not configured. Run: jeriko gdrive init', EXIT.AUTH);
  }

  const res = await httpsPost('oauth2.googleapis.com', '/token', {
    client_id: clientId,
    client_secret: clientSecret,
    refresh_token: refreshToken,
    grant_type: 'refresh_token',
  });

  const data = JSON.parse(res.body.toString());
  if (res.statusCode >= 400 || data.error) {
    const msg = data.error_description || data.error || `HTTP ${res.statusCode}`;
    fail(`Token refresh failed: ${msg}. Run: jeriko gdrive init`, EXIT.AUTH);
  }

  _cachedAccessToken = data.access_token;
  return _cachedAccessToken;
}

// ---- Google Drive API helper ----

async function gdrive(method, urlPath, body = null, query = {}) {
  const token = await getAccessToken();
  const url = new URL(urlPath.startsWith('http') ? urlPath : `https://www.googleapis.com${urlPath}`);
  for (const [k, v] of Object.entries(query)) {
    if (v !== undefined && v !== null) url.searchParams.set(k, v);
  }

  const bodyStr = body ? JSON.stringify(body) : null;

  const options = {
    hostname: url.hostname,
    path: url.pathname + url.search,
    method,
    headers: {
      'Authorization': `Bearer ${token}`,
      'Accept': 'application/json',
      'User-Agent': 'JerikoBot',
    },
  };

  if (bodyStr) {
    options.headers['Content-Type'] = 'application/json';
    options.headers['Content-Length'] = Buffer.byteLength(bodyStr);
  }

  return new Promise((resolve) => {
    const req = https.request(options, (res) => {
      let data = '';
      res.on('data', (chunk) => { data += chunk; });
      res.on('end', () => {
        // 204 No Content
        if (res.statusCode === 204) return resolve(null);

        let parsed;
        try { parsed = JSON.parse(data); } catch {
          if (res.statusCode >= 400) {
            fail(`Google Drive ${res.statusCode}: ${data.slice(0, 200)}`, EXIT.GENERAL);
          }
          return resolve(data);
        }

        if (res.statusCode >= 400) {
          const msg = parsed.error?.message || JSON.stringify(parsed);
          const code = (res.statusCode === 401 || res.statusCode === 403) ? EXIT.AUTH
            : res.statusCode === 404 ? EXIT.NOT_FOUND : EXIT.GENERAL;
          fail(`Google Drive ${res.statusCode}: ${msg}`, code);
        }

        resolve(parsed);
      });
    });

    req.on('error', (err) => {
      fail(`Google Drive request failed: ${err.message}`, EXIT.NETWORK);
    });

    if (bodyStr) req.write(bodyStr);
    req.end();
  });
}

// Binary download helper — returns a Buffer
async function gdriveDownload(urlPath, query = {}) {
  const token = await getAccessToken();
  const url = new URL(urlPath.startsWith('http') ? urlPath : `https://www.googleapis.com${urlPath}`);
  for (const [k, v] of Object.entries(query)) {
    if (v !== undefined && v !== null) url.searchParams.set(k, v);
  }

  const res = await httpsRequest({
    hostname: url.hostname,
    path: url.pathname + url.search,
    method: 'GET',
    headers: {
      'Authorization': `Bearer ${token}`,
      'User-Agent': 'JerikoBot',
    },
  });

  // Follow redirects (Google sometimes returns 307/302)
  if (res.statusCode === 301 || res.statusCode === 302 || res.statusCode === 307 || res.statusCode === 308) {
    const loc = res.headers.location;
    if (loc) return gdriveDownload(loc, {});
  }

  if (res.statusCode >= 400) {
    let msg;
    try {
      const parsed = JSON.parse(res.body.toString());
      msg = parsed.error?.message || JSON.stringify(parsed);
    } catch {
      msg = res.body.toString().slice(0, 200);
    }
    const code = (res.statusCode === 401 || res.statusCode === 403) ? EXIT.AUTH
      : res.statusCode === 404 ? EXIT.NOT_FOUND : EXIT.GENERAL;
    fail(`Google Drive ${res.statusCode}: ${msg}`, code);
  }

  return res.body;
}

// Multipart upload helper
async function gdriveUpload(metadata, fileBuffer, mimeType) {
  const token = await getAccessToken();
  const boundary = 'jeriko_upload_boundary_' + Date.now();

  // Build multipart body
  const metaPart = Buffer.from(
    `--${boundary}\r\n` +
    `Content-Type: application/json; charset=UTF-8\r\n\r\n` +
    JSON.stringify(metadata) + `\r\n`
  );
  const filePart = Buffer.from(
    `--${boundary}\r\n` +
    `Content-Type: ${mimeType}\r\n\r\n`
  );
  const closing = Buffer.from(`\r\n--${boundary}--`);
  const body = Buffer.concat([metaPart, filePart, fileBuffer, closing]);

  const res = await httpsRequest({
    hostname: 'www.googleapis.com',
    path: '/upload/drive/v3/files?uploadType=multipart',
    method: 'POST',
    headers: {
      'Authorization': `Bearer ${token}`,
      'Content-Type': `multipart/related; boundary=${boundary}`,
      'Content-Length': body.length,
      'User-Agent': 'JerikoBot',
    },
  }, body);

  let parsed;
  try { parsed = JSON.parse(res.body.toString()); } catch {
    if (res.statusCode >= 400) {
      fail(`Upload failed: HTTP ${res.statusCode} — ${res.body.toString().slice(0, 200)}`, EXIT.GENERAL);
    }
    return res.body.toString();
  }

  if (res.statusCode >= 400) {
    const msg = parsed.error?.message || JSON.stringify(parsed);
    fail(`Upload failed: ${msg}`, EXIT.GENERAL);
  }

  return parsed;
}

// Verification helper (used during init)
async function gdriveVerify(accessToken) {
  return new Promise((resolve) => {
    const req = https.request({
      hostname: 'www.googleapis.com',
      path: '/drive/v3/about?fields=user,storageQuota',
      method: 'GET',
      headers: {
        'Authorization': `Bearer ${accessToken}`,
        'Accept': 'application/json',
        'User-Agent': 'JerikoBot',
      },
    }, (res) => {
      let data = '';
      res.on('data', (chunk) => { data += chunk; });
      res.on('end', () => {
        try {
          const parsed = JSON.parse(data);
          resolve({ ok: res.statusCode < 400, status: res.statusCode, data: parsed });
        } catch {
          resolve({ ok: false, status: res.statusCode, data: null });
        }
      });
    });
    req.on('error', (err) => resolve({ ok: false, status: 0, data: null, error: err.message }));
    req.end();
  });
}

// Guess MIME type from extension
function guessMime(filePath) {
  const ext = path.extname(filePath).toLowerCase();
  const map = {
    '.pdf': 'application/pdf',
    '.doc': 'application/msword',
    '.docx': 'application/vnd.openxmlformats-officedocument.wordprocessingml.document',
    '.xls': 'application/vnd.ms-excel',
    '.xlsx': 'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet',
    '.ppt': 'application/vnd.ms-powerpoint',
    '.pptx': 'application/vnd.openxmlformats-officedocument.presentationml.presentation',
    '.txt': 'text/plain',
    '.csv': 'text/csv',
    '.html': 'text/html',
    '.htm': 'text/html',
    '.json': 'application/json',
    '.xml': 'application/xml',
    '.zip': 'application/zip',
    '.gz': 'application/gzip',
    '.tar': 'application/x-tar',
    '.png': 'image/png',
    '.jpg': 'image/jpeg',
    '.jpeg': 'image/jpeg',
    '.gif': 'image/gif',
    '.bmp': 'image/bmp',
    '.svg': 'image/svg+xml',
    '.webp': 'image/webp',
    '.mp3': 'audio/mpeg',
    '.wav': 'audio/wav',
    '.mp4': 'video/mp4',
    '.mov': 'video/quicktime',
    '.avi': 'video/x-msvideo',
    '.mkv': 'video/x-matroska',
    '.js': 'application/javascript',
    '.ts': 'application/typescript',
    '.py': 'text/x-python',
    '.md': 'text/markdown',
    '.yaml': 'text/yaml',
    '.yml': 'text/yaml',
  };
  return map[ext] || 'application/octet-stream';
}

// Format file size
function formatSize(bytes) {
  if (bytes === undefined || bytes === null) return null;
  const n = parseInt(bytes);
  if (isNaN(n)) return null;
  if (n < 1024) return `${n} B`;
  if (n < 1024 * 1024) return `${(n / 1024).toFixed(1)} KB`;
  if (n < 1024 * 1024 * 1024) return `${(n / (1024 * 1024)).toFixed(1)} MB`;
  return `${(n / (1024 * 1024 * 1024)).toFixed(2)} GB`;
}

// ---- Command router ----

run(async () => {
  const args = process.argv.slice(2);
  const command = args[0];
  // Parse flags from everything after command
  const { flags, positional: allPositional } = parseArgs(['', '', ...args.slice(1)]);
  const positional = allPositional;

  if (!command) {
    return ok({
      usage: 'jeriko gdrive <command> [flags]',
      commands: {
        init: 'interactive OAuth2 setup wizard',
        list: 'list files (--folder, --type, --limit)',
        search: 'search files by name',
        info: 'file metadata',
        download: 'download or export a file',
        upload: 'upload a file',
        mkdir: 'create a folder',
        share: 'share a file or folder',
        delete: 'trash or permanently delete a file',
        about: 'storage usage and user info',
      },
    });
  }

  // ===================== INIT =====================
  if (command === 'init') {
    const w = (s) => process.stderr.write(s);
    w('\n');
    w(`  ${C.bold}${C.cyan}Google Drive Setup${C.reset}\n`);
    w(`  ${C.dim}Files, folders, search, upload, download${C.reset}\n`);
    w('\n');

    // Non-interactive: jeriko gdrive init --client-id xxx --client-secret xxx --refresh-token xxx
    if (flags['refresh-token']) {
      if (flags['client-id']) writeEnvKey('GOOGLE_DRIVE_CLIENT_ID', flags['client-id']);
      if (flags['client-secret']) writeEnvKey('GOOGLE_DRIVE_CLIENT_SECRET', flags['client-secret']);
      writeEnvKey('GOOGLE_DRIVE_REFRESH_TOKEN', flags['refresh-token']);

      // Verify if all three are present
      const cid = flags['client-id'] || process.env.GOOGLE_DRIVE_CLIENT_ID;
      const csec = flags['client-secret'] || process.env.GOOGLE_DRIVE_CLIENT_SECRET;
      if (cid && csec) {
        try {
          const tokenRes = await httpsPost('oauth2.googleapis.com', '/token', {
            client_id: cid,
            client_secret: csec,
            refresh_token: flags['refresh-token'],
            grant_type: 'refresh_token',
          });
          const tokenData = JSON.parse(tokenRes.body.toString());
          if (tokenData.access_token) {
            const verifyRes = await gdriveVerify(tokenData.access_token);
            if (verifyRes.ok) {
              w(`  ${C.green}[ok]${C.reset} Credentials verified (${verifyRes.data.user?.displayName || verifyRes.data.user?.emailAddress})\n\n`);
            } else {
              w(`  ${C.red}[!!]${C.reset} Credentials saved but verification failed\n\n`);
            }
          } else {
            w(`  ${C.red}[!!]${C.reset} Credentials saved but token refresh failed: ${tokenData.error_description || tokenData.error}\n\n`);
          }
        } catch (e) {
          w(`  ${C.red}[!!]${C.reset} Credentials saved but verification failed: ${e.message}\n\n`);
        }
      } else {
        w(`  ${C.green}[ok]${C.reset} GOOGLE_DRIVE_REFRESH_TOKEN saved\n\n`);
      }
      return ok({ status: 'configured' });
    }

    const rl = readline.createInterface({
      input: process.stdin,
      output: process.stderr,
      terminal: true,
    });

    const env = readEnv();
    const existingId = env.GOOGLE_DRIVE_CLIENT_ID;
    const existingSecret = env.GOOGLE_DRIVE_CLIENT_SECRET;
    const existingRefresh = env.GOOGLE_DRIVE_REFRESH_TOKEN;

    // Step 1: Client ID
    w(`  ${C.bold}Step 1/3: OAuth2 Client Credentials${C.reset}\n`);
    w(`  ${C.dim}Create an OAuth2 client at:${C.reset}\n`);
    w(`  ${C.cyan}https://console.cloud.google.com/apis/credentials${C.reset}\n`);
    w(`  ${C.dim}Application type: Desktop app (or TV / Limited Input)${C.reset}\n`);
    w(`  ${C.dim}Enable the Google Drive API at:${C.reset}\n`);
    w(`  ${C.cyan}https://console.cloud.google.com/apis/library/drive.googleapis.com${C.reset}\n\n`);

    let clientId;
    if (existingId) {
      w(`  ${C.dim}Current client ID: ${maskKey(existingId)}${C.reset}\n`);
      const keep = await ask(rl, 'Keep existing client ID? (Y/n)', 'Y');
      if (keep.toLowerCase() === 'n') {
        clientId = await ask(rl, 'Client ID:');
      } else {
        clientId = existingId;
      }
    } else {
      clientId = await ask(rl, 'Client ID:');
    }

    if (!clientId) {
      w(`\n  ${C.dim}Skipped — no client ID provided${C.reset}\n\n`);
      rl.close();
      return ok({ status: 'skipped' });
    }

    // Step 2: Client Secret
    let clientSecret;
    if (existingSecret && existingId === clientId) {
      w(`\n  ${C.dim}Current client secret: ${maskKey(existingSecret)}${C.reset}\n`);
      const keep = await ask(rl, 'Keep existing client secret? (Y/n)', 'Y');
      if (keep.toLowerCase() === 'n') {
        clientSecret = await ask(rl, 'Client Secret:');
      } else {
        clientSecret = existingSecret;
      }
    } else {
      clientSecret = await ask(rl, 'Client Secret:');
    }

    if (!clientSecret) {
      w(`\n  ${C.dim}Skipped — no client secret provided${C.reset}\n\n`);
      rl.close();
      return ok({ status: 'skipped' });
    }

    writeEnvKey('GOOGLE_DRIVE_CLIENT_ID', clientId);
    writeEnvKey('GOOGLE_DRIVE_CLIENT_SECRET', clientSecret);
    w(`\n  ${C.green}[ok]${C.reset} Client credentials saved to .env\n`);

    // Step 3: OAuth2 Device Flow (or skip if refresh token already exists)
    let refreshToken = null;
    if (existingRefresh && existingId === clientId) {
      w(`\n  ${C.dim}Current refresh token: ${maskKey(existingRefresh)}${C.reset}\n`);
      const keep = await ask(rl, 'Keep existing refresh token? (Y/n)', 'Y');
      if (keep.toLowerCase() !== 'n') {
        refreshToken = existingRefresh;
      }
    }

    if (!refreshToken) {
      w(`\n  ${C.bold}Step 2/3: Authorization${C.reset}\n`);
      w(`  ${C.dim}Starting device authorization flow...${C.reset}\n\n`);

      // Request device code
      const scope = 'https://www.googleapis.com/auth/drive';
      let deviceRes;
      try {
        deviceRes = await httpsPost('oauth2.googleapis.com', '/device/code', {
          client_id: clientId,
          scope,
        });
      } catch (e) {
        w(`  ${C.red}[!!]${C.reset} Failed to start device flow: ${e.message}\n`);
        w(`  ${C.dim}Make sure your OAuth client type is "Desktop" or "TVs and Limited Input devices"${C.reset}\n\n`);
        rl.close();
        return ok({ status: 'error', error: e.message });
      }

      const deviceData = JSON.parse(deviceRes.body.toString());
      if (deviceRes.statusCode >= 400 || deviceData.error) {
        const errMsg = deviceData.error_description || deviceData.error || `HTTP ${deviceRes.statusCode}`;
        w(`  ${C.red}[!!]${C.reset} Device code request failed: ${errMsg}\n`);
        w(`  ${C.dim}Ensure the OAuth client supports device flow and Drive API is enabled${C.reset}\n\n`);
        rl.close();
        return ok({ status: 'error', error: errMsg });
      }

      const { device_code, user_code, verification_url, expires_in, interval: pollInterval } = deviceData;
      const verifyUrl = verification_url || deviceData.verification_uri || 'https://www.google.com/device';

      w(`  ${C.bold}Open this URL in your browser:${C.reset}\n`);
      w(`  ${C.cyan}${verifyUrl}${C.reset}\n\n`);
      w(`  ${C.bold}Enter this code:${C.reset} ${C.yellow}${user_code}${C.reset}\n\n`);

      await ask(rl, 'Press Enter after you have authorized in your browser...');

      // Poll for token
      w('\n');
      const frames = ['.  ', '.. ', '...', '   '];
      let fi = 0;
      const spin = setInterval(() => {
        process.stderr.write(`\r  ${C.dim}Waiting for authorization${frames[fi++ % frames.length]}${C.reset}`);
      }, 200);

      const pollMs = ((pollInterval || 5) + 1) * 1000; // respect rate limit + 1s buffer
      const deadline = Date.now() + (expires_in || 1800) * 1000;
      let tokenData = null;

      while (Date.now() < deadline) {
        await new Promise(r => setTimeout(r, pollMs));
        try {
          const tokenRes = await httpsPost('oauth2.googleapis.com', '/token', {
            client_id: clientId,
            client_secret: clientSecret,
            device_code,
            grant_type: 'urn:ietf:params:oauth:grant-type:device_code',
          });
          const td = JSON.parse(tokenRes.body.toString());
          if (td.access_token && td.refresh_token) {
            tokenData = td;
            break;
          }
          if (td.error === 'authorization_pending') continue;
          if (td.error === 'slow_down') {
            await new Promise(r => setTimeout(r, 5000));
            continue;
          }
          if (td.error === 'expired_token' || td.error === 'access_denied') {
            clearInterval(spin);
            process.stderr.write(`\r${' '.repeat(60)}\r`);
            w(`  ${C.red}[!!]${C.reset} Authorization ${td.error === 'expired_token' ? 'expired' : 'denied'}: ${td.error_description || td.error}\n\n`);
            rl.close();
            return ok({ status: 'error', error: td.error });
          }
        } catch {
          // Network error, retry
          continue;
        }
      }

      clearInterval(spin);
      process.stderr.write(`\r${' '.repeat(60)}\r`);

      if (!tokenData) {
        w(`  ${C.red}[!!]${C.reset} Authorization timed out. Run: jeriko gdrive init\n\n`);
        rl.close();
        return ok({ status: 'timeout' });
      }

      refreshToken = tokenData.refresh_token;
      w(`  ${C.green}[ok]${C.reset} Authorization successful\n`);
    }

    writeEnvKey('GOOGLE_DRIVE_REFRESH_TOKEN', refreshToken);
    w(`  ${C.green}[ok]${C.reset} GOOGLE_DRIVE_REFRESH_TOKEN saved to .env\n`);

    // Step 3: Verify
    w('\n');
    w(`  ${C.bold}Step 3/3: Verification${C.reset}\n`);
    const vFrames = ['.  ', '.. ', '...', '   '];
    let vfi = 0;
    const vSpin = setInterval(() => {
      process.stderr.write(`\r  ${C.dim}Verifying${vFrames[vfi++ % vFrames.length]}${C.reset}`);
    }, 200);

    let verified = false;
    let userName = null;
    let userEmail = null;

    try {
      const tokenRes = await httpsPost('oauth2.googleapis.com', '/token', {
        client_id: clientId,
        client_secret: clientSecret,
        refresh_token: refreshToken,
        grant_type: 'refresh_token',
      });
      const tokenData = JSON.parse(tokenRes.body.toString());
      clearInterval(vSpin);

      if (tokenData.access_token) {
        const verifyRes = await gdriveVerify(tokenData.access_token);
        if (verifyRes.ok) {
          verified = true;
          userName = verifyRes.data.user?.displayName;
          userEmail = verifyRes.data.user?.emailAddress;
          const quota = verifyRes.data.storageQuota;
          process.stderr.write(`\r  ${C.green}[ok]${C.reset} Verified${' '.repeat(30)}\n`);
          if (userName) w(`  ${C.green}[ok]${C.reset} User: ${C.bold}${userName}${C.reset} (${userEmail})\n`);
          if (quota && quota.limit) {
            const used = formatSize(quota.usage);
            const total = formatSize(quota.limit);
            w(`  ${C.green}[ok]${C.reset} Storage: ${used} / ${total}\n`);
          }
        } else {
          process.stderr.write(`\r  ${C.red}[!!]${C.reset} Verification failed: ${verifyRes.data?.error?.message || `HTTP ${verifyRes.status}`}${' '.repeat(20)}\n`);
        }
      } else {
        process.stderr.write(`\r  ${C.red}[!!]${C.reset} Token refresh failed: ${tokenData.error_description || tokenData.error}${' '.repeat(20)}\n`);
      }
    } catch (e) {
      clearInterval(vSpin);
      process.stderr.write(`\r  ${C.red}[!!]${C.reset} Verification failed: ${e.message}${' '.repeat(20)}\n`);
    }

    w('\n');
    w(`  ${C.bold}Next steps:${C.reset}\n`);
    w(`    ${C.cyan}jeriko gdrive about${C.reset}            ${C.dim}# storage usage${C.reset}\n`);
    w(`    ${C.cyan}jeriko gdrive list${C.reset}             ${C.dim}# list files${C.reset}\n`);
    w(`    ${C.cyan}jeriko gdrive search "report"${C.reset}  ${C.dim}# search files${C.reset}\n`);
    w(`    ${C.cyan}jeriko gdrive upload ./file${C.reset}    ${C.dim}# upload a file${C.reset}\n`);
    w('\n');

    rl.close();
    return ok({ status: 'configured', verified, user: userName, email: userEmail });
  }

  // ===================== LIST =====================
  if (command === 'list') {
    const limit = parseInt(flags.limit) || 20;
    const folderId = flags.folder || null;
    const type = flags.type || null;

    const qParts = ['trashed = false'];
    if (folderId) {
      qParts.push(`'${folderId}' in parents`);
    } else if (!type) {
      // Default: list root files
      qParts.push("'root' in parents");
    }
    if (type && TYPE_QUERY_MAP[type]) {
      qParts.push(TYPE_QUERY_MAP[type]);
    }

    const query = {
      q: qParts.join(' and '),
      pageSize: limit,
      fields: 'files(id,name,mimeType,size,modifiedTime,shared,parents),nextPageToken',
      orderBy: flags.sort || 'modifiedTime desc',
    };

    const data = await gdrive('GET', '/drive/v3/files', null, query);
    return ok(data.files.map(f => ({
      id: f.id,
      name: f.name,
      type: f.mimeType,
      size: formatSize(f.size),
      modified: f.modifiedTime,
      shared: f.shared || false,
    })));
  }

  // ===================== SEARCH =====================
  if (command === 'search') {
    const query = positional[0] || flags.query;
    if (!query) fail('Usage: jeriko gdrive search "query" [--type document|spreadsheet|...] [--limit N]');

    const limit = parseInt(flags.limit) || 20;
    const type = flags.type || null;

    const qParts = [`name contains '${query.replace(/'/g, "\\'")}'`, 'trashed = false'];
    if (type && TYPE_QUERY_MAP[type]) {
      qParts.push(TYPE_QUERY_MAP[type]);
    }

    const params = {
      q: qParts.join(' and '),
      pageSize: limit,
      fields: 'files(id,name,mimeType,size,modifiedTime,shared,parents),nextPageToken',
      orderBy: 'modifiedTime desc',
    };

    const data = await gdrive('GET', '/drive/v3/files', null, params);
    return ok(data.files.map(f => ({
      id: f.id,
      name: f.name,
      type: f.mimeType,
      size: formatSize(f.size),
      modified: f.modifiedTime,
      shared: f.shared || false,
    })));
  }

  // ===================== INFO =====================
  if (command === 'info') {
    const fileId = positional[0] || flags.id;
    if (!fileId) fail('Usage: jeriko gdrive info <file_id>');

    const data = await gdrive('GET', `/drive/v3/files/${fileId}`, null, {
      fields: 'id,name,mimeType,size,createdTime,modifiedTime,shared,owners,parents,webViewLink,webContentLink,description,starred,trashed,capabilities,sharingUser,permissions',
    });

    return ok({
      id: data.id,
      name: data.name,
      type: data.mimeType,
      size: formatSize(data.size),
      sizeBytes: data.size ? parseInt(data.size) : null,
      created: data.createdTime,
      modified: data.modifiedTime,
      shared: data.shared || false,
      starred: data.starred || false,
      trashed: data.trashed || false,
      description: data.description || null,
      owners: data.owners?.map(o => ({ name: o.displayName, email: o.emailAddress })),
      parents: data.parents || [],
      webViewLink: data.webViewLink || null,
      webContentLink: data.webContentLink || null,
      permissions: data.permissions?.map(p => ({
        id: p.id,
        type: p.type,
        role: p.role,
        email: p.emailAddress || null,
        displayName: p.displayName || null,
      })),
    });
  }

  // ===================== DOWNLOAD =====================
  if (command === 'download') {
    const fileId = positional[0] || flags.id;
    if (!fileId) fail('Usage: jeriko gdrive download <file_id> [--to ./output.pdf] [--export pdf|docx|txt|csv]');

    // Get file metadata first to determine name and MIME type
    const meta = await gdrive('GET', `/drive/v3/files/${fileId}`, null, {
      fields: 'id,name,mimeType,size',
    });

    const isGoogleDoc = GOOGLE_MIME_TYPES.includes(meta.mimeType);
    const exportFormat = flags.export || null;

    let buf;
    let outputName = meta.name;

    if (isGoogleDoc || exportFormat) {
      // Export Google Docs/Sheets/Slides to a downloadable format
      let exportMime;
      if (exportFormat && EXPORT_MIME_MAP[exportFormat]) {
        exportMime = EXPORT_MIME_MAP[exportFormat];
      } else if (exportFormat) {
        fail(`Unknown export format: "${exportFormat}". Supported: ${Object.keys(EXPORT_MIME_MAP).join(', ')}`);
      } else {
        // Default export formats for Google types
        if (meta.mimeType === 'application/vnd.google-apps.document') exportMime = 'application/pdf';
        else if (meta.mimeType === 'application/vnd.google-apps.spreadsheet') exportMime = 'text/csv';
        else if (meta.mimeType === 'application/vnd.google-apps.presentation') exportMime = 'application/pdf';
        else if (meta.mimeType === 'application/vnd.google-apps.drawing') exportMime = 'image/png';
        else exportMime = 'application/pdf';
      }

      buf = await gdriveDownload(`/drive/v3/files/${fileId}/export`, { mimeType: exportMime });

      // Add extension if not present
      const extMap = {};
      for (const [ext, mime] of Object.entries(EXPORT_MIME_MAP)) {
        if (!extMap[mime]) extMap[mime] = ext;
      }
      const ext = extMap[exportMime];
      if (ext && !outputName.toLowerCase().endsWith(`.${ext}`)) {
        outputName = `${outputName}.${ext}`;
      }
    } else {
      // Regular file download
      buf = await gdriveDownload(`/drive/v3/files/${fileId}`, { alt: 'media' });
    }

    // Write to file
    const outputPath = flags.to || path.join(process.cwd(), outputName);
    const resolvedPath = path.resolve(outputPath);
    fs.writeFileSync(resolvedPath, buf);

    return ok({
      id: fileId,
      name: meta.name,
      savedAs: outputName,
      path: resolvedPath,
      size: formatSize(buf.length),
      sizeBytes: buf.length,
      exported: !!(isGoogleDoc || exportFormat),
    });
  }

  // ===================== UPLOAD =====================
  if (command === 'upload') {
    const filePath = positional[0] || flags.file;
    if (!filePath) fail('Usage: jeriko gdrive upload ./file [--folder <folder_id>] [--name "Custom Name"]');

    const resolvedPath = path.resolve(filePath);
    if (!fs.existsSync(resolvedPath)) {
      fail(`File not found: ${resolvedPath}`, EXIT.NOT_FOUND);
    }

    const fileBuffer = fs.readFileSync(resolvedPath);
    const fileName = flags.name || path.basename(resolvedPath);
    const mimeType = flags.mime || guessMime(resolvedPath);

    const metadata = { name: fileName };
    if (flags.folder) {
      metadata.parents = [flags.folder];
    }

    const data = await gdriveUpload(metadata, fileBuffer, mimeType);

    return ok({
      id: data.id,
      name: data.name,
      type: data.mimeType,
      size: formatSize(fileBuffer.length),
      sizeBytes: fileBuffer.length,
      folder: flags.folder || 'root',
    });
  }

  // ===================== MKDIR =====================
  if (command === 'mkdir') {
    const folderName = positional[0] || flags.name;
    if (!folderName) fail('Usage: jeriko gdrive mkdir "Folder Name" [--parent <folder_id>]');

    const metadata = {
      name: folderName,
      mimeType: 'application/vnd.google-apps.folder',
    };
    if (flags.parent) {
      metadata.parents = [flags.parent];
    }

    const data = await gdrive('POST', '/drive/v3/files', metadata, {
      fields: 'id,name,mimeType,createdTime,webViewLink',
    });

    return ok({
      id: data.id,
      name: data.name,
      type: data.mimeType,
      created: data.createdTime,
      parent: flags.parent || 'root',
      webViewLink: data.webViewLink || null,
    });
  }

  // ===================== SHARE =====================
  if (command === 'share') {
    const fileId = positional[0] || flags.id;
    if (!fileId) fail('Usage: jeriko gdrive share <file_id> --email user@gmail.com [--role writer] OR --anyone');

    if (flags.anyone) {
      // Share with anyone (link sharing)
      const permission = {
        type: 'anyone',
        role: flags.role || 'reader',
      };
      const data = await gdrive('POST', `/drive/v3/files/${fileId}/permissions`, permission, {
        fields: 'id,type,role',
      });

      // Get the web view link
      const fileMeta = await gdrive('GET', `/drive/v3/files/${fileId}`, null, {
        fields: 'webViewLink',
      });

      return ok({
        fileId,
        permissionId: data.id,
        type: data.type,
        role: data.role,
        link: fileMeta.webViewLink || null,
      });
    }

    if (flags.email) {
      const permission = {
        type: 'user',
        role: flags.role || 'reader',
        emailAddress: flags.email,
      };

      const query = {};
      // Send notification email by default; suppress with --no-notify
      if (flags['no-notify']) {
        query.sendNotificationEmail = 'false';
      }
      if (flags.message) {
        query.emailMessage = flags.message;
      }

      const data = await gdrive('POST', `/drive/v3/files/${fileId}/permissions`, permission, {
        fields: 'id,type,role,emailAddress,displayName',
        ...query,
      });

      return ok({
        fileId,
        permissionId: data.id,
        type: data.type,
        role: data.role,
        email: data.emailAddress || flags.email,
        displayName: data.displayName || null,
      });
    }

    fail('Usage: jeriko gdrive share <file_id> --email user@gmail.com [--role writer] OR --anyone');
  }

  // ===================== DELETE =====================
  if (command === 'delete') {
    const fileId = positional[0] || flags.id;
    if (!fileId) fail('Usage: jeriko gdrive delete <file_id> [--permanent]');

    if (flags.permanent) {
      // Permanent delete (no recovery)
      await gdrive('DELETE', `/drive/v3/files/${fileId}`);
      return ok({
        id: fileId,
        deleted: true,
        permanent: true,
      });
    }

    // Move to trash
    const data = await gdrive('PATCH', `/drive/v3/files/${fileId}`, { trashed: true }, {
      fields: 'id,name,trashed',
    });

    return ok({
      id: data.id,
      name: data.name,
      trashed: data.trashed,
      permanent: false,
    });
  }

  // ===================== ABOUT =====================
  if (command === 'about') {
    const data = await gdrive('GET', '/drive/v3/about', null, {
      fields: 'user,storageQuota,maxUploadSize',
    });

    const quota = data.storageQuota || {};

    return ok({
      user: {
        name: data.user?.displayName,
        email: data.user?.emailAddress,
        photo: data.user?.photoLink || null,
      },
      storage: {
        used: formatSize(quota.usage),
        usedBytes: quota.usage ? parseInt(quota.usage) : null,
        limit: formatSize(quota.limit),
        limitBytes: quota.limit ? parseInt(quota.limit) : null,
        usedInDrive: formatSize(quota.usageInDrive),
        usedInTrash: formatSize(quota.usageInDriveTrash),
      },
      maxUploadSize: formatSize(data.maxUploadSize),
    });
  }

  fail(`Unknown command: gdrive ${command}\nRun "jeriko gdrive" for usage.`);
});
