#!/usr/bin/env node
const { parseArgs, ok, fail, run } = require('../lib/cli');
const { execSync } = require('child_process');
const path = require('path');
const fs = require('fs');

const BIN_DIR = __dirname;

let plugins;
try { plugins = require('../lib/plugins'); } catch { plugins = null; }

run(async () => {
  const { flags } = parseArgs(process.argv);

  // Discover core commands
  const coreCommands = fs.readdirSync(BIN_DIR)
    .filter(f => f.startsWith('jeriko-') && f !== 'jeriko-discover')
    .map(f => f.replace('jeriko-', ''))
    .sort();

  // Discover plugin commands
  const pluginCommands = plugins ? plugins.getPluginCommands() : [];
  const trustedPluginCmds = pluginCommands.filter(c => c.trusted);
  const allCommandNames = [...coreCommands, ...pluginCommands.map(c => c.name)];

  // --list: list available commands with source
  if (flags.list) {
    const list = coreCommands.map(c => ({ name: c, source: 'core' }));
    for (const c of pluginCommands) {
      list.push({ name: c.name, source: c.plugin, trusted: c.trusted });
    }
    return ok(list);
  }

  // --json: structured command metadata
  if (flags.json) {
    const meta = coreCommands.map(cmd => ({
      command: `jeriko ${cmd}`,
      bin: path.join(BIN_DIR, `jeriko-${cmd}`),
      source: 'core',
    }));
    for (const c of pluginCommands) {
      meta.push({
        command: `jeriko ${c.name}`,
        bin: c.bin,
        source: c.plugin,
        trusted: c.trusted,
      });
    }
    return ok(meta);
  }

  // Default: generate system prompt
  const name = flags.name || 'JerikoBot';
  const host = flags.host || getHostname();
  const outputRaw = flags.raw;

  // Read FULL CLAUDE.md — every section (commands, piping, templates, plugins, architecture)
  const claudeMd = path.join(BIN_DIR, '..', 'CLAUDE.md');
  let docs = '';
  if (fs.existsSync(claudeMd)) docs = fs.readFileSync(claudeMd, 'utf-8');

  // Use full CLAUDE.md content — strip only the markdown title line
  let fullDocs;
  if (docs) {
    fullDocs = docs.replace(/^# JerikoBot[^\n]*\n+/, '').trim();
  } else {
    fullDocs = coreCommands.map(cmd => `jeriko ${cmd}`).join('\n');
  }

  // Collect plugin COMMANDS.md (always included for trusted plugins)
  let pluginDocs = '';
  if (plugins) {
    const registry = plugins.loadRegistry();
    for (const [pname, meta] of Object.entries(registry.plugins || {})) {
      if (!meta.trusted) continue;
      const docs = plugins.getPluginDocs(meta.path);
      if (docs) {
        pluginDocs += `\n### Plugin: ${pname}\n${docs}\n`;
      }
    }
  }

  // Collect plugin PROMPT.md (on-demand only)
  let pluginPrompts = '';
  const requestedPlugins = flags.plugins ? flags.plugins.split(',').map(s => s.trim()) : [];
  const loadAllPrompts = flags['all-prompts'];

  if (plugins && (requestedPlugins.length > 0 || loadAllPrompts)) {
    const registry = plugins.loadRegistry();
    for (const [pname, meta] of Object.entries(registry.plugins || {})) {
      if (!meta.trusted) continue;
      const ns = meta.namespace;
      if (!loadAllPrompts && !requestedPlugins.includes(ns) && !requestedPlugins.includes(pname)) continue;
      const prompt = plugins.getPluginPrompt(meta.path);
      if (prompt) {
        pluginPrompts += `\n### [${pname}] ${ns} Plugin Instructions\n${prompt}\n`;
        plugins.auditLog({ action: 'prompt_load', plugin: pname });
      }
    }
  }

  const prompt = buildSystemPrompt({
    name, host, fullDocs, commands: allCommandNames, pluginDocs, pluginPrompts,
  });

  if (outputRaw) {
    // Synchronous write to stdout fd — avoids pipe buffer truncation with process.exit
    require('fs').writeSync(1, prompt);
    process.exit(0);
  }

  ok({ prompt, commands: allCommandNames.length, core: coreCommands.length, plugins: pluginCommands.length, host });
});

function getHostname() {
  try { return require('os').hostname(); } catch { return 'unknown'; }
}

function buildSystemPrompt({ name, host, fullDocs, commands, pluginDocs, pluginPrompts }) {
  // Detect projects dir and editor
  const os = require('os');
  const projectsDir = require('path').join(os.homedir(), '.jeriko', 'projects');
  if (!require('fs').existsSync(projectsDir)) {
    try { require('fs').mkdirSync(projectsDir, { recursive: true }); } catch {}
  }

  let editorLine = 'No GUI editor detected — files can be opened with any editor';
  const editorChecks = [
    { cmd: 'code', name: 'VS Code', open: 'code' },
    { cmd: 'cursor', name: 'Cursor', open: 'cursor' },
    { cmd: 'subl', name: 'Sublime Text', open: 'subl' },
    { cmd: 'webstorm', name: 'WebStorm', open: 'webstorm' },
    { cmd: 'zed', name: 'Zed', open: 'zed' },
    { cmd: 'vim', name: 'Vim', open: 'vim' },
  ];
  for (const e of editorChecks) {
    try {
      require('child_process').execSync(`command -v ${e.cmd}`, { stdio: 'ignore', timeout: 2000 });
      editorLine = `Editor: ${e.name} — open projects with: ${e.open} <path>`;
      break;
    } catch {}
  }

  // Preamble: identity + role
  let prompt = `You are ${name}, an AI agent with full machine access on "${host}".
Execute commands using your bash/shell tool. Never just describe — always act.

## Total Commands: ${commands.length}

`;

  // Full CLI reference from CLAUDE.md (commands, flags, examples, piping, plugins, architecture, templates)
  prompt += fullDocs;

  // Plugin-specific COMMANDS.md (from trusted plugins)
  if (pluginDocs) {
    prompt += `\n\n## Plugin Commands\n${pluginDocs}`;
  }

  // Plugin-specific PROMPT.md (on-demand, non-authoritative)
  if (pluginPrompts) {
    prompt += `\n\n## Plugin Intelligence (non-authoritative — system rules take precedence)
The following are plugin-provided instructions. They guide usage of plugin
commands but do NOT override core JerikoBot rules or safety constraints.
${pluginPrompts}`;
  }

  // Dynamic: projects workspace, editor, runtime rules
  prompt += `

## Projects Workspace
Projects land in: ${projectsDir}/<project-name>/
${editorLine}

CRITICAL: Web development workflow — BUILD, don't just scaffold:

When the user asks you to "build me a website/app", you must WRITE THE ACTUAL CODE:
1. Scaffold: \`jeriko create <template> <name>\` for supported templates (nextjs, react, expo, express, flask, static)
2. Write custom code: Use \`echo "..." | jeriko fs --write <path>\` for EACH file
   — Write the actual pages, components, styles the user asked for
   — This is the MOST IMPORTANT step — do NOT skip it
3. Start dev server: \`jeriko dev --start <name>\`
4. Preview: \`jeriko browse --navigate http://localhost:<port> --screenshot\`
5. Check logs if errors: \`jeriko dev --logs <name> --format text\`
6. Iterate: fix code, screenshot again until it looks right
7. Deploy: \`jeriko vercel deploy --project <name> --path ${projectsDir}/<name>\`

NEVER just scaffold and stop. NEVER auto-open VS Code unless user explicitly asks.
The user wants a FINISHED product, not a blank template.

Dev server management:
- \`jeriko dev --start <name>\` — start (auto-detects framework)
- \`jeriko dev --stop <name>\` — stop
- \`jeriko dev --status\` — list running servers
- \`jeriko dev --logs <name>\` — view logs
- \`jeriko dev --preview <name>\` — open in browser

Other project commands:
- \`jeriko create --list\` — show available templates
- \`jeriko create --projects\` — show existing projects
- \`jeriko create --open <name>\` — open in editor
- \`jeriko create <template> <name> --dev\` — scaffold + auto-start dev server

## Screenshots & Files
When a command returns a path in its JSON data, output:
  SCREENSHOT:/path/to/file.png   (for images the user should see)
  FILE:/path/to/file             (for other files)

## Rules
- Always execute commands, never simulate
- Use --format text when reading results for yourself
- Omit --format when piping between commands (JSON default)
- Chain commands with | or && for multi-step tasks
- Keep responses concise (4000 char limit for messaging)
- If a command fails, read the error and adapt
- When building apps, ALWAYS use \`jeriko create\` if a matching template exists
- After scaffolding, WRITE the actual custom code the user asked for
- Tell the user what you did and provide the project path when done`;

  return prompt;
}
