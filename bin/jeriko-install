#!/usr/bin/env node
const { parseArgs, ok, fail, run, EXIT } = require('../lib/cli');
const { execSync } = require('child_process');
const path = require('path');
const fs = require('fs');
const {
  getPluginDir, loadRegistry, saveRegistry,
  loadManifest, validateManifest,
  checkConflicts, computeIntegrity, auditLog,
} = require('../lib/plugins');

run(async () => {
  const { flags, positional } = parseArgs(process.argv);

  // --list: show installed plugins
  if (flags.list) {
    const registry = loadRegistry();
    const plugins = Object.entries(registry.plugins || {}).map(([name, meta]) => ({
      name,
      version: meta.version,
      namespace: meta.namespace,
      commands: (meta.commands || []).join(', '),
      trusted: meta.trusted || false,
    }));
    return ok(plugins);
  }

  // --info <name>: show plugin details
  if (flags.info) {
    const name = typeof flags.info === 'string' ? flags.info : positional[0];
    if (!name) fail('Usage: jeriko install --info <name>');
    const registry = loadRegistry();
    const meta = (registry.plugins || {})[name];
    if (!meta) fail(`Plugin "${name}" is not installed`, EXIT.NOT_FOUND);
    const manifest = loadManifest(meta.path);
    return ok({
      name,
      version: meta.version,
      namespace: meta.namespace,
      path: meta.path,
      commands: meta.commands,
      permissions: manifest?.permissions || [],
      env: (manifest?.env || []).map(e => ({ key: e.key, required: e.required })),
      platform: manifest?.platform || [],
      trusted: meta.trusted || false,
      integrity: meta.integrity,
      installedAt: meta.installedAt,
    });
  }

  // --upgrade <name>: upgrade existing plugin to latest
  if (flags.upgrade) {
    const name = typeof flags.upgrade === 'string' ? flags.upgrade : positional[0];
    if (!name) fail('Usage: jeriko install --upgrade <name>');
    const registry = loadRegistry();
    const existing = (registry.plugins || {})[name];
    if (!existing) fail(`Plugin "${name}" is not installed`, EXIT.NOT_FOUND);
    const wasTrusted = existing.trusted || false;
    const installDir = path.join(getPluginDir(), name);

    try {
      execSync(`npm install ${name}@latest --prefix "${installDir}"`, {
        encoding: 'utf-8',
        timeout: 60000,
        stdio: ['pipe', 'pipe', 'pipe'],
      });
    } catch (e) {
      fail(`npm install failed: ${e.stderr || e.message}`, EXIT.NETWORK);
    }

    const pkgPath = path.join(installDir, 'node_modules', name);
    if (!fs.existsSync(pkgPath)) fail(`Package not found after install: ${pkgPath}`, EXIT.NOT_FOUND);

    const manifest = loadManifest(pkgPath);
    const errors = validateManifest(manifest);
    if (errors.length) fail(`Invalid manifest:\n  ${errors.join('\n  ')}`);

    if (manifest.platform && !manifest.platform.includes(process.platform)) {
      fail(`Plugin requires ${manifest.platform.join('|')} but running on ${process.platform}`);
    }

    const conflicts = checkConflicts(manifest, registry);
    if (conflicts.length) fail(`Conflicts:\n  ${conflicts.join('\n  ')}`);

    for (const cmd of manifest.commands) {
      const binPath = path.join(pkgPath, cmd.bin);
      if (fs.existsSync(binPath)) fs.chmodSync(binPath, 0o755);
    }

    const integrity = computeIntegrity(pkgPath);

    registry.plugins[name] = {
      version: manifest.version,
      namespace: manifest.namespace,
      path: pkgPath,
      commands: manifest.commands.map(c => c.name),
      permissions: manifest.permissions || [],
      integrity,
      trusted: wasTrusted,
      installedAt: existing.installedAt,
      upgradedAt: new Date().toISOString(),
    };
    saveRegistry(registry);

    auditLog({
      action: 'upgrade',
      plugin: name,
      from: existing.version,
      to: manifest.version,
      trusted: wasTrusted,
    });

    return ok({
      upgraded: name,
      from: existing.version,
      to: manifest.version,
      commands: manifest.commands.map(c => c.name),
      trusted: wasTrusted,
    });
  }

  // Install: positional arg is the package spec
  const spec = positional[0];
  if (!spec) fail('Usage: jeriko install <package|./path> [--list] [--info <name>] [--upgrade <name>]');

  const isLocal = spec.startsWith('./') || spec.startsWith('/') || spec.startsWith('../');
  let npmArg, pkgName;

  if (isLocal) {
    // Local path install (dev mode)
    const absPath = path.resolve(spec);
    if (!fs.existsSync(absPath)) fail(`Path not found: ${absPath}`, EXIT.NOT_FOUND);
    // Read package name from the local package.json or manifest
    const localPkg = path.join(absPath, 'package.json');
    if (!fs.existsSync(localPkg)) fail(`No package.json found at ${absPath}`);
    const pkg = JSON.parse(fs.readFileSync(localPkg, 'utf-8'));
    pkgName = pkg.name;
    npmArg = absPath;
  } else {
    // npm package: parse name@version
    const atIdx = spec.lastIndexOf('@');
    if (atIdx > 0) {
      pkgName = spec.slice(0, atIdx);
      npmArg = spec; // name@version
    } else {
      pkgName = spec;
      npmArg = spec;
    }
  }

  if (!pkgName) fail('Could not determine package name');

  const installDir = path.join(getPluginDir(), pkgName);
  fs.mkdirSync(installDir, { recursive: true });

  // Run npm install
  try {
    execSync(`npm install ${npmArg} --prefix "${installDir}"`, {
      encoding: 'utf-8',
      timeout: 60000,
      stdio: ['pipe', 'pipe', 'pipe'],
    });
  } catch (e) {
    fail(`npm install failed: ${e.stderr || e.message}`, EXIT.NETWORK);
  }

  // Locate installed package in node_modules
  const pkgPath = path.join(installDir, 'node_modules', pkgName);
  if (!fs.existsSync(pkgPath)) fail(`Package not found after install: ${pkgPath}`, EXIT.NOT_FOUND);

  // Read and validate manifest
  const manifest = loadManifest(pkgPath);
  const errors = validateManifest(manifest);
  if (errors.length) fail(`Invalid jeriko-plugin.json:\n  ${errors.join('\n  ')}`);

  // Platform check
  if (manifest.platform && !manifest.platform.includes(process.platform)) {
    fail(`Plugin requires ${manifest.platform.join('|')} but running on ${process.platform}`);
  }

  // Conflict check
  const registry = loadRegistry();
  const conflicts = checkConflicts(manifest, registry);
  if (conflicts.length) fail(`Conflicts:\n  ${conflicts.join('\n  ')}`);

  // chmod +x all bin files
  for (const cmd of manifest.commands) {
    const binPath = path.join(pkgPath, cmd.bin);
    if (fs.existsSync(binPath)) fs.chmodSync(binPath, 0o755);
  }

  // Compute integrity
  const integrity = computeIntegrity(pkgPath);

  // Write to registry (preserve trust if reinstalling)
  registry.plugins = registry.plugins || {};
  const existing = registry.plugins[manifest.name];
  const wasTrusted = existing?.trusted || false;
  registry.plugins[manifest.name] = {
    version: manifest.version,
    namespace: manifest.namespace,
    path: pkgPath,
    commands: manifest.commands.map(c => c.name),
    permissions: manifest.permissions || [],
    integrity,
    trusted: wasTrusted,
    installedAt: existing?.installedAt || new Date().toISOString(),
    ...(existing ? { upgradedAt: new Date().toISOString() } : {}),
  };
  saveRegistry(registry);

  // Audit log
  auditLog({
    action: 'install',
    plugin: manifest.name,
    version: manifest.version,
    namespace: manifest.namespace,
    local: isLocal,
    commands: manifest.commands.map(c => c.name),
  });

  // Summary
  const result = {
    installed: manifest.name,
    version: manifest.version,
    namespace: manifest.namespace,
    commands: manifest.commands.map(c => c.name),
    path: pkgPath,
    trusted: wasTrusted,
  };
  if (!wasTrusted) result.warning = `Plugin is UNTRUSTED. Run "jeriko trust ${manifest.name}" to review and trust.`;

  return ok(result);
});
