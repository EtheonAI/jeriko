#!/usr/bin/env node
const { parseArgs, ok, fail, run, EXIT } = require('../lib/cli');
const { loadManifest, validateManifest, checkConflicts, loadRegistry, computeIntegrity, RESERVED } = require('../lib/plugins');
const { execSync } = require('child_process');
const path = require('path');
const fs = require('fs');

const VALID_CODES = [0, 1, 2, 3, 5, 7];

run(async () => {
  const { flags, positional } = parseArgs(process.argv);
  const sub = positional[0];

  if (flags.validate || sub === 'validate') {
    const p = flags.validate === true ? positional[0] : (typeof flags.validate === 'string' ? flags.validate : positional[1]);
    if (!p) fail('Usage: jeriko plugin validate <path>');
    return validate(path.resolve(p));
  }
  if (flags.test || sub === 'test') {
    const p = flags.test === true ? positional[0] : (typeof flags.test === 'string' ? flags.test : positional[1]);
    if (!p) fail('Usage: jeriko plugin test <path>');
    return test(path.resolve(p));
  }
  if (flags.scaffold || sub === 'scaffold') fail('scaffold is not yet implemented');
  fail('Usage: jeriko plugin validate|test|scaffold <path>');
});

// ---- Validate ----
function validate(pluginPath) {
  const errors = [];
  const warnings = [];

  // 1. Check jeriko-plugin.json exists
  if (!fs.existsSync(path.join(pluginPath, 'jeriko-plugin.json'))) {
    fail(`jeriko-plugin.json not found at ${pluginPath}`, EXIT.NOT_FOUND);
  }
  // 2. Load and validate manifest
  const manifest = loadManifest(pluginPath);
  if (!manifest) fail('Failed to parse jeriko-plugin.json', EXIT.GENERAL);
  errors.push(...validateManifest(manifest));

  // 3. Check all bin files exist and are executable
  for (const cmd of manifest.commands || []) {
    if (!cmd.bin) continue;
    const bin = path.join(pluginPath, cmd.bin);
    if (!fs.existsSync(bin)) { errors.push(`Bin file missing: ${cmd.bin}`); continue; }
    try { fs.accessSync(bin, fs.constants.X_OK); } catch { errors.push(`Bin file not executable: ${cmd.bin}`); }
  }
  // 4-5. Check optional docs
  if (!fs.existsSync(path.join(pluginPath, 'COMMANDS.md'))) warnings.push('COMMANDS.md not found (recommended for discovery)');
  if (!fs.existsSync(path.join(pluginPath, 'PROMPT.md'))) warnings.push('PROMPT.md not found (recommended for AI context)');

  // 6. Check platform includes current
  if (Array.isArray(manifest.platform) && !manifest.platform.includes(process.platform)) {
    warnings.push(`Current platform "${process.platform}" not in supported: [${manifest.platform.join(', ')}]`);
  }
  // 7. Namespace reserved check (also in validateManifest — kept for explicit step)
  // 8. Check conflicts against registry
  errors.push(...checkConflicts(manifest, loadRegistry()));

  // 9. Compute integrity hash
  const integrity = computeIntegrity(pluginPath);

  // 10. Summary
  if (errors.length > 0) {
    fail({ valid: false, plugin: manifest.name || 'unknown', namespace: manifest.namespace || 'unknown', errors, warnings, integrity });
  }
  ok({
    valid: true, plugin: manifest.name, namespace: manifest.namespace,
    version: manifest.version, commands: (manifest.commands || []).map(c => c.name),
    platform: manifest.platform, warnings: warnings.length ? warnings : undefined, integrity,
  });
}

// ---- Test ----
function test(pluginPath) {
  const manifest = loadManifest(pluginPath);
  if (!manifest) fail('Failed to load jeriko-plugin.json', EXIT.NOT_FOUND);
  const mErr = validateManifest(manifest);
  if (mErr.length) fail({ valid: false, errors: mErr });

  const results = [];
  for (const cmd of manifest.commands || []) {
    const binPath = path.join(pluginPath, cmd.bin);
    if (!fs.existsSync(binPath)) { results.push({ command: cmd.name, status: 'skip', reason: 'bin not found' }); continue; }

    const entry = { command: cmd.name, json: null, text: null, exitCode: null };

    // a. Run with no args — expect JSON with ok field
    try {
      const out = execSync(`node "${binPath}"`, { encoding: 'utf-8', timeout: 15000, env: { ...process.env, JERIKO_FORMAT: 'json' }, stdio: ['pipe', 'pipe', 'pipe'] });
      try { const p = JSON.parse(out.trim()); entry.json = (p.ok === true || p.ok === false) ? 'pass' : 'fail: missing ok field'; }
      catch { entry.json = 'fail: output is not valid JSON'; }
      entry.exitCode = 0;
    } catch (e) {
      entry.exitCode = e.status ?? -1;
      if (VALID_CODES.includes(entry.exitCode)) {
        try { const p = JSON.parse((e.stderr || '').trim()); entry.json = p.ok === false ? 'pass' : 'fail: error missing ok:false'; }
        catch { entry.json = 'fail: error output is not valid JSON'; }
      } else { entry.json = `fail: unexpected exit code ${entry.exitCode}`; }
    }

    // b. Run with --format text — verify output is not JSON
    try {
      const out = execSync(`node "${binPath}" --format text`, { encoding: 'utf-8', timeout: 15000, env: { ...process.env, JERIKO_FORMAT: 'text' }, stdio: ['pipe', 'pipe', 'pipe'] });
      try { JSON.parse(out.trim()); entry.text = 'fail: text format returned JSON'; } catch { entry.text = 'pass'; }
    } catch (e) {
      try { JSON.parse((e.stderr || '').trim()); entry.text = 'fail: text error returned JSON'; } catch { entry.text = 'pass'; }
    }

    // c. Check exit code is valid
    entry.exitCodeValid = VALID_CODES.includes(entry.exitCode) ? 'pass' : `fail: code ${entry.exitCode}`;
    entry.status = [entry.json, entry.text, entry.exitCodeValid].every(v => v === 'pass') ? 'pass' : 'fail';
    results.push(entry);
  }

  const passed = results.filter(r => r.status === 'pass').length;
  const failed = results.filter(r => r.status === 'fail').length;
  const skipped = results.filter(r => r.status === 'skip').length;
  ok({ plugin: manifest.name, passed, failed, skipped, total: results.length, results });
}
