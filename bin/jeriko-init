#!/usr/bin/env node
const readline = require('readline');
const { parseArgs, ok, fail, run, EXIT } = require('../lib/cli');
const { execSync, spawn } = require('child_process');
const crypto = require('crypto');
const path = require('path');
const fs = require('fs');

const ROOT = path.join(__dirname, '..');
const ENV_PATH = path.join(ROOT, '.env');
const JERIKO_BIN = path.join(__dirname, 'jeriko');

// ── Colors ───────────────────────────────────────────────────────────
const C = {
  cyan: '\x1b[36m',
  blue: '\x1b[34m',
  bold: '\x1b[1m',
  dim: '\x1b[2m',
  green: '\x1b[32m',
  red: '\x1b[31m',
  yellow: '\x1b[33m',
  reset: '\x1b[0m',
  gray: '\x1b[90m',
  white: '\x1b[37m',
};

const w = (s) => process.stderr.write(s);

// ── Helpers ──────────────────────────────────────────────────────────

function ask(rl, question, defaultValue) {
  const defLabel = defaultValue !== undefined ? ` ${C.dim}(${defaultValue})${C.reset}` : '';
  return new Promise((resolve) => {
    rl.question(`  ${C.cyan}?${C.reset} ${question}${defLabel} `, (answer) => {
      resolve(answer.trim() || (defaultValue !== undefined ? String(defaultValue) : ''));
    });
  });
}

function maskKey(key) {
  if (!key || key.length < 10) return '***';
  return key.slice(0, 8) + '...' + key.slice(-4);
}

function spinner(msg) {
  const frames = ['.  ', '.. ', '...', '   '];
  let i = 0;
  w(`  ${C.dim}${msg}`);
  const interval = setInterval(() => {
    w(`\r  ${C.dim}${msg}${frames[i++ % frames.length]}${C.reset}`);
  }, 200);
  return {
    stop(result, isOk = true) {
      clearInterval(interval);
      const icon = isOk ? `${C.green}[ok]${C.reset}` : `${C.red}[!!]${C.reset}`;
      w(`\r  ${icon} ${result}${' '.repeat(20)}\n`);
    }
  };
}

function readEnv() {
  if (!fs.existsSync(ENV_PATH)) return {};
  const lines = fs.readFileSync(ENV_PATH, 'utf-8').split('\n');
  const env = {};
  for (const line of lines) {
    const m = line.match(/^\s*([A-Z_][A-Z0-9_]*)\s*=\s*(.*)/);
    if (m) env[m[1]] = m[2].replace(/^["']|["']$/g, '');
  }
  return env;
}

function writeEnvKey(key, value) {
  let content = fs.existsSync(ENV_PATH) ? fs.readFileSync(ENV_PATH, 'utf-8') : '';
  const regex = new RegExp(`^\\s*#?\\s*${key}\\s*=.*$`, 'm');
  const line = `${key}=${value}`;
  if (regex.test(content)) {
    // Overwrite existing key (even if commented out)
    content = content.replace(regex, line);
    fs.writeFileSync(ENV_PATH, content);
  } else {
    // Append
    fs.appendFileSync(ENV_PATH, (content && !content.endsWith('\n') ? '\n' : '') + line + '\n');
  }
}

function ensureEnvFile() {
  if (!fs.existsSync(ENV_PATH)) {
    const example = path.join(ROOT, '.env.example');
    if (fs.existsSync(example)) {
      fs.copyFileSync(example, ENV_PATH);
    } else {
      fs.writeFileSync(ENV_PATH, '');
    }
  }
}

async function verifyAnthropic(key) {
  const res = await fetch('https://api.anthropic.com/v1/messages', {
    method: 'POST',
    headers: {
      'x-api-key': key,
      'anthropic-version': '2023-06-01',
      'content-type': 'application/json',
    },
    body: JSON.stringify({
      model: 'claude-sonnet-4-20250514',
      max_tokens: 1,
      messages: [{ role: 'user', content: 'hi' }],
    }),
  });
  if (!res.ok) {
    const body = await res.json().catch(() => ({}));
    throw new Error(body.error?.message || `HTTP ${res.status}`);
  }
  return true;
}

async function verifyOpenAI(key) {
  const res = await fetch('https://api.openai.com/v1/chat/completions', {
    method: 'POST',
    headers: {
      'Authorization': `Bearer ${key}`,
      'Content-Type': 'application/json',
    },
    body: JSON.stringify({
      model: 'gpt-4o-mini',
      max_tokens: 1,
      messages: [{ role: 'user', content: 'hi' }],
    }),
  });
  if (!res.ok) {
    const body = await res.json().catch(() => ({}));
    throw new Error(body.error?.message || `HTTP ${res.status}`);
  }
  return true;
}

async function verifyTelegram(token) {
  const res = await fetch(`https://api.telegram.org/bot${token}/getMe`);
  const body = await res.json();
  if (!body.ok) throw new Error(body.description || 'Invalid token');
  return body.result;
}

// ── Main ─────────────────────────────────────────────────────────────

run(async () => {
  const { flags } = parseArgs(process.argv);
  const summary = { steps: [] };

  // ── Banner ──
  w('\n');
  w(`  ${C.bold}${C.cyan}JerikoBot Setup${C.reset}\n`);
  w(`  ${C.dim}Unix-first AI toolkit${C.reset}\n`);
  w('\n');

  ensureEnvFile();

  // ── Detect mode ──
  // Non-interactive if --yes flag or any config flags passed
  const hasConfigFlags = flags.ai || flags['telegram-token'] || flags['admin-ids'];
  const nonInteractive = flags.yes === true || hasConfigFlags;
  const skipAI = flags['skip-ai'] === true;
  const skipTelegram = flags['skip-telegram'] === true;

  let rl;
  if (!nonInteractive) {
    rl = readline.createInterface({
      input: process.stdin,
      output: process.stderr,
      terminal: true,
    });
  }

  // ══════════════════════════════════════════════════════════════════
  // Step 1/6: AI Backend
  // ══════════════════════════════════════════════════════════════════
  w(`  ${C.bold}${C.cyan}[1/6] AI Backend${C.reset}\n`);

  if (skipAI) {
    w(`  ${C.dim}      Skipped (--skip-ai)${C.reset}\n`);
    summary.steps.push({ step: 'ai_backend', status: 'skipped' });
  } else {
    const env = readEnv();
    let backend;

    if (nonInteractive) {
      backend = flags.ai || env.AI_BACKEND || 'claude-code';
    } else {
      w('\n');
      w(`    ${C.white}1${C.reset}  ${C.bold}claude-code${C.reset}  ${C.dim}— Claude Code CLI (dev, no API key)${C.reset}\n`);
      w(`    ${C.white}2${C.reset}  ${C.bold}claude${C.reset}       ${C.dim}— Anthropic API (production)${C.reset}\n`);
      w(`    ${C.white}3${C.reset}  ${C.bold}openai${C.reset}       ${C.dim}— OpenAI API${C.reset}\n`);
      w(`    ${C.white}4${C.reset}  ${C.bold}local${C.reset}        ${C.dim}— Ollama / LM Studio / any local model (no cloud)${C.reset}\n`);
      w('\n');

      const existing = env.AI_BACKEND;
      const def = existing || '1';
      const choice = await ask(rl, `Enter 1, 2, 3, or 4:`, def);
      const map = { '1': 'claude-code', '2': 'claude', '3': 'openai', '4': 'local',
                     'claude-code': 'claude-code', 'claude': 'claude', 'openai': 'openai', 'local': 'local' };
      backend = map[choice] || map[def];
    }

    backend = backend.toLowerCase();
    if (!['claude-code', 'claude', 'openai', 'local'].includes(backend)) {
      fail(`Invalid AI backend: ${backend}. Use "claude-code", "claude", "openai", or "local".`);
    }

    writeEnvKey('AI_BACKEND', backend);
    w(`  ${C.green}[ok]${C.reset} AI_BACKEND=${backend}\n`);

    // Ask for API key if needed
    if (backend === 'claude' && !nonInteractive) {
      const existingKey = env.ANTHROPIC_API_KEY;
      if (existingKey) {
        const keep = await ask(rl, `ANTHROPIC_API_KEY already set (${maskKey(existingKey)}). Keep it? (Y/n)`, 'Y');
        if (keep.toLowerCase() === 'n') {
          const key = await ask(rl, 'Anthropic API key:');
          if (key) {
            const s = spinner('Verifying API key');
            try {
              await verifyAnthropic(key);
              s.stop(`API key verified (${maskKey(key)})`);
              writeEnvKey('ANTHROPIC_API_KEY', key);
            } catch (e) {
              s.stop(`Verification failed: ${e.message}`, false);
              w(`  ${C.yellow}      Saving key anyway — check it later${C.reset}\n`);
              writeEnvKey('ANTHROPIC_API_KEY', key);
            }
          }
        }
      } else {
        const key = await ask(rl, 'Anthropic API key:');
        if (key) {
          const s = spinner('Verifying API key');
          try {
            await verifyAnthropic(key);
            s.stop(`API key verified (${maskKey(key)})`);
            writeEnvKey('ANTHROPIC_API_KEY', key);
          } catch (e) {
            s.stop(`Verification failed: ${e.message}`, false);
            w(`  ${C.yellow}      Saving key anyway — check it later${C.reset}\n`);
            writeEnvKey('ANTHROPIC_API_KEY', key);
          }
        }
      }
    } else if (backend === 'claude' && nonInteractive) {
      // Non-interactive: use flag or existing
      if (flags['anthropic-key']) writeEnvKey('ANTHROPIC_API_KEY', flags['anthropic-key']);
    }

    if (backend === 'openai' && !nonInteractive) {
      const existingKey = env.OPENAI_API_KEY;
      if (existingKey) {
        const keep = await ask(rl, `OPENAI_API_KEY already set (${maskKey(existingKey)}). Keep it? (Y/n)`, 'Y');
        if (keep.toLowerCase() === 'n') {
          const key = await ask(rl, 'OpenAI API key:');
          if (key) {
            const s = spinner('Verifying API key');
            try {
              await verifyOpenAI(key);
              s.stop(`API key verified (${maskKey(key)})`);
              writeEnvKey('OPENAI_API_KEY', key);
            } catch (e) {
              s.stop(`Verification failed: ${e.message}`, false);
              w(`  ${C.yellow}      Saving key anyway — check it later${C.reset}\n`);
              writeEnvKey('OPENAI_API_KEY', key);
            }
          }
        }
      } else {
        const key = await ask(rl, 'OpenAI API key:');
        if (key) {
          const s = spinner('Verifying API key');
          try {
            await verifyOpenAI(key);
            s.stop(`API key verified (${maskKey(key)})`);
            writeEnvKey('OPENAI_API_KEY', key);
          } catch (e) {
            s.stop(`Verification failed: ${e.message}`, false);
            w(`  ${C.yellow}      Saving key anyway — check it later${C.reset}\n`);
            writeEnvKey('OPENAI_API_KEY', key);
          }
        }
      }
    } else if (backend === 'openai' && nonInteractive) {
      if (flags['openai-key']) writeEnvKey('OPENAI_API_KEY', flags['openai-key']);
    }

    // Local model setup
    if (backend === 'local' && !nonInteractive) {
      w('\n');

      // Auto-detect Ollama
      let ollamaRunning = false;
      let ollamaModels = [];
      const s = spinner('Detecting local model server');
      try {
        const res = await fetch('http://localhost:11434/api/tags', { signal: AbortSignal.timeout(3000) });
        if (res.ok) {
          const body = await res.json();
          ollamaModels = (body.models || []).map(m => m.name);
          ollamaRunning = true;
          s.stop(`Ollama detected (${ollamaModels.length} model${ollamaModels.length !== 1 ? 's' : ''} available)`);
        } else {
          throw new Error();
        }
      } catch {
        // Try LM Studio
        try {
          const res2 = await fetch('http://localhost:1234/v1/models', { signal: AbortSignal.timeout(3000) });
          if (res2.ok) {
            s.stop('LM Studio detected');
          } else {
            throw new Error();
          }
        } catch {
          s.stop('No local model server detected', false);
          w(`  ${C.dim}      Start Ollama: ollama serve${C.reset}\n`);
          w(`  ${C.dim}      Or LM Studio: https://lmstudio.ai${C.reset}\n`);
        }
      }

      // List available Ollama models
      if (ollamaModels.length > 0) {
        w('\n');
        w(`  ${C.dim}  Available models:${C.reset}\n`);
        for (const m of ollamaModels.slice(0, 10)) {
          w(`    ${C.cyan}-${C.reset} ${m}\n`);
        }
        if (ollamaModels.length > 10) w(`    ${C.dim}... and ${ollamaModels.length - 10} more${C.reset}\n`);
        w('\n');
      }

      // Model URL
      const existingUrl = env.LOCAL_MODEL_URL;
      const defaultUrl = ollamaRunning ? 'http://localhost:11434/v1' : (existingUrl || 'http://localhost:11434/v1');
      const url = await ask(rl, 'Model API URL:', defaultUrl);
      writeEnvKey('LOCAL_MODEL_URL', url);
      w(`  ${C.green}[ok]${C.reset} LOCAL_MODEL_URL=${url}\n`);

      // Model name
      const existingModel = env.LOCAL_MODEL;
      const defaultModel = ollamaModels.length > 0 ? ollamaModels[0] : (existingModel || 'llama3.2');
      const model = await ask(rl, 'Model name:', defaultModel);
      writeEnvKey('LOCAL_MODEL', model);
      w(`  ${C.green}[ok]${C.reset} LOCAL_MODEL=${model}\n`);

      // Optional API key
      const existingKey = env.LOCAL_API_KEY;
      if (existingKey) {
        w(`  ${C.dim}      LOCAL_API_KEY already set${C.reset}\n`);
      } else {
        const key = await ask(rl, 'API key (optional, press Enter to skip):', '');
        if (key) {
          writeEnvKey('LOCAL_API_KEY', key);
          w(`  ${C.green}[ok]${C.reset} LOCAL_API_KEY set\n`);
        }
      }

      // Verify model is reachable
      const sv = spinner('Verifying model connection');
      try {
        const verifyRes = await fetch(`${url}/models`, { signal: AbortSignal.timeout(5000) });
        if (verifyRes.ok) {
          sv.stop(`Connected to ${model}`);
        } else {
          throw new Error();
        }
      } catch {
        sv.stop('Could not reach model server — start it before using JerikoBot', false);
      }
    } else if (backend === 'local' && nonInteractive) {
      if (flags['local-url']) writeEnvKey('LOCAL_MODEL_URL', flags['local-url']);
      if (flags['local-model']) writeEnvKey('LOCAL_MODEL', flags['local-model']);
      if (flags['local-key']) writeEnvKey('LOCAL_API_KEY', flags['local-key']);
    }

    summary.steps.push({ step: 'ai_backend', status: 'configured', value: backend });
  }

  w('\n');

  // ══════════════════════════════════════════════════════════════════
  // Step 2/6: Telegram Bot
  // ══════════════════════════════════════════════════════════════════
  w(`  ${C.bold}${C.cyan}[2/6] Telegram Bot${C.reset}\n`);

  if (skipTelegram) {
    w(`  ${C.dim}      Skipped (--skip-telegram)${C.reset}\n`);
    summary.steps.push({ step: 'telegram', status: 'skipped' });
  } else {
    const env = readEnv();

    if (nonInteractive) {
      // Non-interactive: use flags or keep existing
      if (flags['telegram-token']) {
        writeEnvKey('TELEGRAM_BOT_TOKEN', flags['telegram-token']);
        w(`  ${C.green}[ok]${C.reset} TELEGRAM_BOT_TOKEN set\n`);
      }
      if (flags['admin-ids']) {
        writeEnvKey('ADMIN_TELEGRAM_IDS', flags['admin-ids']);
        w(`  ${C.green}[ok]${C.reset} ADMIN_TELEGRAM_IDS set\n`);
      }
      if (!flags['telegram-token'] && !flags['admin-ids']) {
        if (env.TELEGRAM_BOT_TOKEN) {
          w(`  ${C.dim}      Already configured${C.reset}\n`);
        } else {
          w(`  ${C.dim}      Skipped (no flags provided)${C.reset}\n`);
        }
      }
      summary.steps.push({ step: 'telegram', status: flags['telegram-token'] ? 'configured' : (env.TELEGRAM_BOT_TOKEN ? 'exists' : 'skipped') });
    } else {
      w('\n');
      const setupTg = await ask(rl, 'Set up Telegram bot? (Y/n)', 'Y');
      if (setupTg.toLowerCase() === 'n') {
        w(`  ${C.dim}      Skipped${C.reset}\n`);
        summary.steps.push({ step: 'telegram', status: 'skipped' });
      } else {
        // Bot token
        const existingToken = env.TELEGRAM_BOT_TOKEN;
        let token;
        if (existingToken) {
          const keep = await ask(rl, `Bot token already set (${maskKey(existingToken)}). Keep it? (Y/n)`, 'Y');
          token = keep.toLowerCase() === 'n' ? null : existingToken;
        }
        if (!token) {
          w(`  ${C.dim}      Create a bot at: https://t.me/BotFather${C.reset}\n`);
          token = await ask(rl, 'Bot token:');
        }

        if (token && token !== existingToken) {
          const s = spinner('Verifying bot token');
          try {
            const bot = await verifyTelegram(token);
            s.stop(`Bot verified: @${bot.username}`);
            writeEnvKey('TELEGRAM_BOT_TOKEN', token);
          } catch (e) {
            s.stop(`Verification failed: ${e.message}`, false);
            w(`  ${C.yellow}      Saving token anyway — check it later${C.reset}\n`);
            writeEnvKey('TELEGRAM_BOT_TOKEN', token);
          }
        } else if (token === existingToken) {
          w(`  ${C.green}[ok]${C.reset} Keeping existing bot token\n`);
        }

        // Admin IDs
        const existingIds = env.ADMIN_TELEGRAM_IDS;
        let ids;
        if (existingIds) {
          const keep = await ask(rl, `Admin IDs already set (${existingIds}). Keep? (Y/n)`, 'Y');
          ids = keep.toLowerCase() === 'n' ? null : existingIds;
        }
        if (!ids) {
          w(`  ${C.dim}      Send /start to @userinfobot to get your ID${C.reset}\n`);
          ids = await ask(rl, 'Admin Telegram ID(s) (comma-separated):');
        }
        if (ids && ids !== existingIds) {
          writeEnvKey('ADMIN_TELEGRAM_IDS', ids);
          w(`  ${C.green}[ok]${C.reset} ADMIN_TELEGRAM_IDS=${ids}\n`);
        }

        summary.steps.push({ step: 'telegram', status: 'configured' });
      }
    }
  }

  w('\n');

  // ══════════════════════════════════════════════════════════════════
  // Step 3/6: Security
  // ══════════════════════════════════════════════════════════════════
  w(`  ${C.bold}${C.cyan}[3/6] Security${C.reset}\n`);
  {
    const env = readEnv();

    // NODE_AUTH_SECRET
    if (env.NODE_AUTH_SECRET) {
      w(`  ${C.green}[ok]${C.reset} NODE_AUTH_SECRET already set\n`);
    } else {
      const secret = crypto.randomBytes(32).toString('hex');
      writeEnvKey('NODE_AUTH_SECRET', secret);
      w(`  ${C.green}[ok]${C.reset} Generated NODE_AUTH_SECRET\n`);
    }

    // PROXY_PORT
    if (!env.PROXY_PORT) {
      writeEnvKey('PROXY_PORT', '3000');
      w(`  ${C.green}[ok]${C.reset} PROXY_PORT=3000\n`);
    } else {
      w(`  ${C.green}[ok]${C.reset} PROXY_PORT=${env.PROXY_PORT}\n`);
    }

    // chmod 600 .env
    try {
      fs.chmodSync(ENV_PATH, 0o600);
      w(`  ${C.green}[ok]${C.reset} .env permissions set to 600\n`);
    } catch {
      // Windows or permission issue — not critical
    }

    summary.steps.push({ step: 'security', status: 'configured' });
  }

  w('\n');

  // ══════════════════════════════════════════════════════════════════
  // Step 4/6: Tunnel
  // ══════════════════════════════════════════════════════════════════
  w(`  ${C.bold}${C.cyan}[4/6] Tunnel${C.reset} ${C.dim}(for webhooks)${C.reset}\n`);

  let tunnelChoice = 'none';

  if (nonInteractive) {
    w(`  ${C.dim}      Skipped (non-interactive)${C.reset}\n`);
    summary.steps.push({ step: 'tunnel', status: 'skipped' });
  } else {
    w('\n');
    const setupTunnel = await ask(rl, 'Set up a tunnel for webhooks? (y/N)', 'N');

    if (setupTunnel.toLowerCase() === 'y') {
      w('\n');
      w(`    ${C.white}1${C.reset}  ${C.bold}localtunnel${C.reset}  ${C.dim}— npx package, zero install (Recommended)${C.reset}\n`);
      w(`    ${C.white}2${C.reset}  ${C.bold}cloudflare${C.reset}   ${C.dim}— Cloudflare Tunnel (needs cloudflared)${C.reset}\n`);
      w('\n');

      const choice = await ask(rl, 'Enter 1 or 2:', '1');
      tunnelChoice = choice === '2' ? 'cloudflare' : 'localtunnel';

      if (tunnelChoice === 'cloudflare') {
        // Check for cloudflared binary
        try {
          execSync('command -v cloudflared', { stdio: 'ignore' });
          w(`  ${C.green}[ok]${C.reset} cloudflared found\n`);
        } catch {
          w(`  ${C.yellow}      cloudflared not found${C.reset}\n`);
          const platform = process.platform;
          if (platform === 'darwin') {
            w(`  ${C.dim}      Install: brew install cloudflared${C.reset}\n`);
          } else {
            w(`  ${C.dim}      Install: https://developers.cloudflare.com/cloudflare-one/connections/connect-networks/downloads/${C.reset}\n`);
          }
          const install = await ask(rl, 'Try to install cloudflared now? (y/N)', 'N');
          if (install.toLowerCase() === 'y') {
            const s = spinner('Installing cloudflared');
            try {
              if (platform === 'darwin') {
                execSync('brew install cloudflared', { stdio: 'ignore', timeout: 120000 });
              } else {
                execSync('curl -L --output /tmp/cloudflared https://github.com/cloudflare/cloudflared/releases/latest/download/cloudflared-linux-amd64 && chmod +x /tmp/cloudflared && sudo mv /tmp/cloudflared /usr/local/bin/cloudflared', { stdio: 'ignore', timeout: 120000 });
              }
              s.stop('cloudflared installed');
            } catch (e) {
              s.stop(`Installation failed: ${e.message}`, false);
              tunnelChoice = 'none';
            }
          } else {
            tunnelChoice = 'none';
          }
        }
      }

      if (tunnelChoice !== 'none') {
        writeEnvKey('TUNNEL_PROVIDER', tunnelChoice);
        w(`  ${C.green}[ok]${C.reset} TUNNEL_PROVIDER=${tunnelChoice}\n`);
      }

      summary.steps.push({ step: 'tunnel', status: tunnelChoice !== 'none' ? 'configured' : 'skipped', provider: tunnelChoice });
    } else {
      w(`  ${C.dim}      Skipped${C.reset}\n`);
      summary.steps.push({ step: 'tunnel', status: 'skipped' });
    }
  }

  w('\n');

  // ══════════════════════════════════════════════════════════════════
  // Step 5/6: Start Server
  // ══════════════════════════════════════════════════════════════════
  w(`  ${C.bold}${C.cyan}[5/6] Start Server${C.reset}\n`);

  let serverStarted = false;

  if (nonInteractive) {
    w(`  ${C.dim}      Skipped (non-interactive)${C.reset}\n`);
    summary.steps.push({ step: 'server', status: 'skipped' });
  } else {
    w('\n');
    const startServer = await ask(rl, 'Start JerikoBot server now? (Y/n)', 'Y');

    if (startServer.toLowerCase() !== 'n') {
      // Start server
      const s = spinner('Starting server');
      try {
        execSync(`"${JERIKO_BIN}" server --start`, { timeout: 15000, stdio: 'ignore' });
        const env = readEnv();
        const port = env.PROXY_PORT || '3000';

        // Check if server is actually running
        let pid = '';
        try {
          const statusOut = execSync(`"${JERIKO_BIN}" server --status --format json`, { encoding: 'utf-8', timeout: 5000 });
          const statusData = JSON.parse(statusOut);
          if (statusData.ok && statusData.data) {
            pid = statusData.data.pid ? ` (PID ${statusData.data.pid})` : '';
          }
        } catch { /* ignore */ }

        s.stop(`Server running on port ${port}${pid}`);
        serverStarted = true;
      } catch (e) {
        s.stop(`Failed to start server: ${e.message}`, false);
      }

      // Start tunnel if configured
      if (serverStarted && tunnelChoice !== 'none') {
        const env = readEnv();
        const port = env.PROXY_PORT || '3000';
        const tunnelLog = path.join(ROOT, 'data', 'tunnel.log');

        // Ensure data/ exists
        const dataDir = path.join(ROOT, 'data');
        if (!fs.existsSync(dataDir)) fs.mkdirSync(dataDir, { recursive: true });

        const st = spinner('Starting tunnel');
        try {
          let tunnelProc;
          if (tunnelChoice === 'localtunnel') {
            tunnelProc = spawn('npx', ['localtunnel', '--port', port, '--subdomain', 'jerikobot'], {
              detached: true,
              stdio: ['ignore', fs.openSync(tunnelLog, 'a'), fs.openSync(tunnelLog, 'a')],
            });
          } else {
            tunnelProc = spawn('cloudflared', ['tunnel', '--url', `http://localhost:${port}`], {
              detached: true,
              stdio: ['ignore', fs.openSync(tunnelLog, 'a'), fs.openSync(tunnelLog, 'a')],
            });
          }
          tunnelProc.unref();

          // Wait for URL to appear in log
          let tunnelUrl = '';
          for (let i = 0; i < 30; i++) {
            await new Promise(r => setTimeout(r, 1000));
            try {
              const log = fs.readFileSync(tunnelLog, 'utf-8');
              // localtunnel prints: your url is: https://xxx.loca.lt
              const ltMatch = log.match(/your url is:\s*(https?:\/\/\S+)/i);
              // cloudflared prints URLs like https://xxx.trycloudflare.com
              const cfMatch = log.match(/(https:\/\/[a-z0-9-]+\.trycloudflare\.com)/);
              tunnelUrl = (ltMatch && ltMatch[1]) || (cfMatch && cfMatch[1]) || '';
              if (tunnelUrl) break;
            } catch { /* log not ready yet */ }
          }

          if (tunnelUrl) {
            writeEnvKey('TUNNEL_URL', tunnelUrl);
            st.stop(`Tunnel: ${tunnelUrl}`);
          } else {
            st.stop('Tunnel started (URL pending — check data/tunnel.log)', false);
          }
        } catch (e) {
          st.stop(`Tunnel failed: ${e.message}`, false);
        }
      }

      summary.steps.push({ step: 'server', status: serverStarted ? 'started' : 'failed' });
    } else {
      w(`  ${C.dim}      Skipped${C.reset}\n`);
      summary.steps.push({ step: 'server', status: 'skipped' });
    }
  }

  w('\n');

  // ══════════════════════════════════════════════════════════════════
  // Step 6/6: Verify
  // ══════════════════════════════════════════════════════════════════
  w(`  ${C.bold}${C.cyan}[6/6] Verify${C.reset}\n`);

  const checks = [];

  // Check: jeriko sys
  try {
    execSync(`"${JERIKO_BIN}" sys --format text`, { timeout: 10000, encoding: 'utf-8', stdio: ['ignore', 'pipe', 'ignore'] });
    w(`  ${C.green}[ok]${C.reset} jeriko sys\n`);
    checks.push({ check: 'sys', pass: true });
  } catch {
    w(`  ${C.red}[!!]${C.reset} jeriko sys\n`);
    checks.push({ check: 'sys', pass: false });
  }

  // Check: jeriko discover
  try {
    execSync(`"${JERIKO_BIN}" discover --list --format text`, { timeout: 10000, encoding: 'utf-8', stdio: ['ignore', 'pipe', 'ignore'] });
    w(`  ${C.green}[ok]${C.reset} jeriko discover\n`);
    checks.push({ check: 'discover', pass: true });
  } catch {
    w(`  ${C.red}[!!]${C.reset} jeriko discover\n`);
    checks.push({ check: 'discover', pass: false });
  }

  // Check: jeriko exec
  try {
    execSync(`"${JERIKO_BIN}" exec echo "ready" --format text`, { timeout: 10000, encoding: 'utf-8', stdio: ['ignore', 'pipe', 'ignore'] });
    w(`  ${C.green}[ok]${C.reset} jeriko exec\n`);
    checks.push({ check: 'exec', pass: true });
  } catch {
    w(`  ${C.red}[!!]${C.reset} jeriko exec\n`);
    checks.push({ check: 'exec', pass: false });
  }

  // Check: server health (only if started)
  if (serverStarted) {
    try {
      const env = readEnv();
      const port = env.PROXY_PORT || '3000';
      const res = await fetch(`http://localhost:${port}/`);
      if (res.ok) {
        w(`  ${C.green}[ok]${C.reset} server health (port ${port})\n`);
        checks.push({ check: 'server', pass: true });
      } else {
        throw new Error(`HTTP ${res.status}`);
      }
    } catch {
      w(`  ${C.red}[!!]${C.reset} server health\n`);
      checks.push({ check: 'server', pass: false });
    }
  }

  summary.steps.push({ step: 'verify', checks });

  // ── Done ───────────────────────────────────────────────────────────
  const passed = checks.filter(c => c.pass).length;
  const total = checks.length;

  w('\n');
  w(`  ${C.bold}${C.green}Setup complete!${C.reset} ${passed}/${total} checks passed.\n`);
  w('\n');
  w(`  ${C.bold}Next steps:${C.reset}\n`);
  w(`    ${C.cyan}jeriko${C.reset}          ${C.dim}# interactive chat${C.reset}\n`);
  w(`    ${C.cyan}jeriko sys${C.reset}      ${C.dim}# test system info${C.reset}\n`);
  w(`    ${C.cyan}jeriko --help${C.reset}   ${C.dim}# all commands${C.reset}\n`);
  w('\n');
  w(`  ${C.dim}Config: ${ENV_PATH}${C.reset}\n`);
  w('\n');

  if (rl) rl.close();
  ok(summary);
});
