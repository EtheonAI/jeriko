#!/usr/bin/env node
const { parseArgs, ok, fail, run, escapeAppleScript: esc } = require('../lib/cli');
const { execSync } = require('child_process');

function osascript(script) {
  return execSync('osascript', { input: script, encoding: 'utf-8', timeout: 15000 }).trim();
}

run(async () => {
  const { flags, positional } = parseArgs(process.argv);

  if (flags.today || flags.week || (!flags.create && !flags.calendars)) {
    const days = flags.week ? 7 : 1;
    const raw = osascript(`
      set now to current date
      set endDate to now + (${days} * days)
      tell application "Calendar"
        set output to ""
        repeat with cal in calendars
          set evts to (every event of cal whose start date >= now and start date <= endDate)
          repeat with e in evts
            set output to output & summary of e & "|" & (start date of e as string) & "|" & (end date of e as string) & "|" & name of cal & linefeed
          end repeat
        end repeat
        return output
      end tell
    `);
    const events = raw.split('\n').filter(Boolean).map(line => {
      const [summary, start, end, calendar] = line.split('|');
      return { summary, start, end, calendar };
    });
    return ok(events);
  }

  if (flags.create) {
    const title = esc(typeof flags.create === 'string' ? flags.create : positional.join(' '));
    if (!title) fail('Usage: jeriko calendar --create "Meeting" --start "Feb 24, 2026 2:00 PM" --end "Feb 24, 2026 3:00 PM"');
    if (!flags.start) fail('--start is required');
    const endStr = esc(flags.end || '');
    const cal = esc(flags.calendar || '');
    const calScript = cal ? `of calendar "${cal}"` : 'of first calendar';
    const endScript = endStr ? `, end date: date "${endStr}"` : '';
    osascript(`
      tell application "Calendar"
        make new event ${calScript} with properties {summary:"${title}", start date: date "${esc(flags.start)}"${endScript}}
      end tell
    `);
    return ok({ created: title, start: flags.start, end: endStr || null });
  }

  if (flags.calendars) {
    const raw = osascript(`
      tell application "Calendar"
        set output to ""
        repeat with c in calendars
          set output to output & name of c & linefeed
        end repeat
        return output
      end tell
    `);
    return ok(raw.split('\n').filter(Boolean));
  }

  fail('Usage: jeriko calendar [--today|--week|--create <title>|--calendars]');
});
