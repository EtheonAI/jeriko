#!/usr/bin/env node
const readline = require('readline');
const path = require('path');
const { execSync } = require('child_process');

// ── Colors & Symbols ────────────────────────────────────────────────
const C = {
  blue: '\x1b[34m',
  bBlue: '\x1b[94m',
  cyan: '\x1b[36m',
  bCyan: '\x1b[96m',
  bold: '\x1b[1m',
  dim: '\x1b[2m',
  reset: '\x1b[0m',
  gray: '\x1b[90m',
  white: '\x1b[37m',
  bWhite: '\x1b[97m',
  green: '\x1b[32m',
  bGreen: '\x1b[92m',
  yellow: '\x1b[33m',
  red: '\x1b[31m',
  magenta: '\x1b[35m',
  bMagenta: '\x1b[95m',
  italic: '\x1b[3m',
  underline: '\x1b[4m',
  bgDim: '\x1b[48;5;236m',
  bgGreen: '\x1b[48;5;22m',
  bgBlue: '\x1b[48;5;24m',
};

const SYM = {
  dot: '\u2022',          // •
  arrow: '\u25B8',        // ▸
  check: '\u2713',        // ✓
  cross: '\u2717',        // ✗
  bar: '\u2502',          // │
  topLeft: '\u256D',      // ╭
  topRight: '\u256E',     // ╮
  botLeft: '\u2570',      // ╰
  botRight: '\u256F',     // ╯
  hLine: '\u2500',        // ─
  thinking: '\u25CF',     // ●
  circle: '\u25CB',       // ○
  halfCircle: '\u25D0',   // ◐
  block: '\u2588',        // █
  lightBlock: '\u2591',   // ░
  medBlock: '\u2592',     // ▒
  connect: '\u2502',      // │
  turnRight: '\u2514',    // └
  teeRight: '\u251C',     // ├
};

const JERIKO = path.join(__dirname, 'jeriko');

// ── Helpers ─────────────────────────────────────────────────────────
function getVersion() {
  try {
    const pkg = require(path.join(__dirname, '..', 'package.json'));
    return pkg.version || '1.0.0';
  } catch { return '1.0.0'; }
}

function getBackend() {
  try {
    require(path.join(__dirname, '..', 'lib', 'cli.js'));
  } catch { /* ignore */ }
  return process.env.AI_BACKEND || 'claude';
}

function getCommandCount() {
  try {
    const raw = execSync(`node "${JERIKO}" discover --list --format json`, {
      encoding: 'utf-8', timeout: 3000, stdio: ['ignore', 'pipe', 'ignore'],
    });
    const parsed = JSON.parse(raw);
    if (parsed.ok && Array.isArray(parsed.data)) return parsed.data.length;
  } catch { /* ignore */ }
  return 46;
}

function getRecentActivity() {
  try {
    const raw = execSync(`node "${JERIKO}" memory --recent 3 --format json`, {
      encoding: 'utf-8', timeout: 3000, stdio: ['ignore', 'pipe', 'ignore'],
    });
    const parsed = JSON.parse(raw);
    if (parsed.ok && Array.isArray(parsed.data)) {
      return parsed.data.map(entry => {
        const cmd = entry.command || '';
        return cmd.length > 35 ? cmd.slice(0, 32) + '...' : cmd;
      }).filter(Boolean);
    }
  } catch { /* ignore */ }
  return [];
}

function elapsed(ms) {
  if (ms < 1000) return `${ms}ms`;
  if (ms < 60000) return `${(ms / 1000).toFixed(1)}s`;
  return `${Math.floor(ms / 60000)}m ${Math.round((ms % 60000) / 1000)}s`;
}

function truncCmd(cmd, max = 55) {
  const clean = cmd.replace(/\n/g, ' ').trim();
  return clean.length > max ? clean.slice(0, max - 3) + '...' : clean;
}

function termWidth() {
  try { return process.stdout.columns || 80; } catch { return 80; }
}

// ── Progress Bar ────────────────────────────────────────────────────
function progressBar(completed, total, width = 24) {
  if (total === 0) return '';
  const pct = Math.round((completed / total) * 100);
  const filled = Math.round((completed / total) * width);
  const empty = width - filled;
  const bar = `${C.green}${SYM.block.repeat(filled)}${C.gray}${SYM.lightBlock.repeat(empty)}${C.reset}`;
  const label = pct >= 100
    ? `${C.bGreen}${C.bold}done${C.reset}`
    : `${C.gray}${pct}%${C.reset}`;
  return `${bar} ${label}`;
}

// ── Spinner ─────────────────────────────────────────────────────────
function createSpinner() {
  const frames = ['⠋', '⠙', '⠹', '⠸', '⠼', '⠴', '⠦', '⠧', '⠇', '⠏'];
  let i = 0;
  let interval = null;
  let currentLabel = 'Thinking';
  let lineLen = 0;
  let startTime = Date.now();

  function render() {
    const dt = elapsed(Date.now() - startTime);
    const frame = frames[i++ % frames.length];
    const text = `  ${C.cyan}${frame}${C.reset} ${C.dim}${currentLabel}${C.reset} ${C.gray}${dt}${C.reset}`;
    const visLen = text.replace(/\x1b\[[0-9;]*m/g, '').length;
    const clearLen = Math.max(lineLen, visLen);
    process.stdout.write(`\r${' '.repeat(clearLen)}\r${text}`);
    lineLen = visLen;
  }

  return {
    start(label) {
      currentLabel = label || 'Thinking';
      startTime = Date.now();
      i = 0;
      if (interval) clearInterval(interval);
      render();
      interval = setInterval(render, 80);
    },
    update(label) { currentLabel = label; },
    stop() {
      if (interval) { clearInterval(interval); interval = null; }
      if (lineLen > 0) process.stdout.write(`\r${' '.repeat(lineLen)}\r`);
      lineLen = 0;
    },
    get active() { return interval !== null; },
  };
}

// ── Ghost Terminal ASCII Art ────────────────────────────────────────
function drawBanner() {
  const version = getVersion();
  const backend = getBackend();
  const cwd = process.cwd().replace(process.env.HOME || '', '~');
  const recent = getRecentActivity();
  const cmds = getCommandCount();

  const b = C.blue, bb = C.bBlue, c = C.cyan, bc = C.bCyan;
  const d = C.dim, w = C.white, bw = C.bWhite, r = C.reset;
  const bo = C.bold, g = C.gray, gr = C.green;

  const truncCwd = cwd.length > 28 ? '~/..' + cwd.slice(-25) : cwd;

  // Ghost terminal — one eye open, one winking
  const ghost = [
    `${bb}        ▄██████████▄${r}`,
    `${bb}      ██${r}${bw}  ${bo}●${r}      ${bo}${C.yellow}━${r}  ${bb}██${r}`,
    `${bb}      ██${r}            ${bb}██${r}`,
    `${bb}      ██${r}    ${w}╰────╯${r}   ${bb}██${r}`,
    `${bb}      ██${r}            ${bb}██${r}`,
    `${bb}      █▀█${r}  ${bb}█▀█${r}  ${bb}█▀█${r}${bb}█${r}`,
    `${b}     ┌──────────────────┐${r}`,
    `${b}     │${r} ${g}$${r} ${w}jeriko${r} ${d}_${r}        ${b}│${r}`,
    `${b}     └──────────────────┘${r}`,
  ];

  // Right panel
  const rightPanel = [
    `${bo}${bc}Jeriko${r} ${d}v${version}${r}`,
    `${d}${backend} ${SYM.dot} ${cmds} commands${r}`,
    `${d}${truncCwd}${r}`,
    ``,
    `${bo}${c}Shortcuts${r}`,
    `${d}  /help     ${g}commands${r}`,
    `${d}  /clear    ${g}reset${r}`,
    `${d}  /exit     ${g}quit${r}`,
  ];

  if (recent.length > 0) {
    rightPanel.push('');
    rightPanel.push(`${bo}${c}Recent${r}`);
    for (const item of recent) rightPanel.push(`${d}  ${SYM.arrow} ${item}${r}`);
  }

  // Compose side by side
  const leftWidth = 32;
  const maxLines = Math.max(ghost.length, rightPanel.length);

  console.log('');

  for (let i = 0; i < maxLines; i++) {
    const left = ghost[i] || '';
    const right = rightPanel[i] || '';
    const leftVisible = left.replace(/\x1b\[[0-9;]*m/g, '').length;
    const pad = Math.max(1, leftWidth - leftVisible);
    console.log(`${left}${' '.repeat(pad)}${right}`);
  }

  console.log('');
}

// ── Slash Commands ──────────────────────────────────────────────────
// Module-level conversation history — cleared by /clear, used by main REPL
let conversationHistory = [];

function runJerikoSync(args) {
  try {
    return execSync(`node "${JERIKO}" ${args}`, {
      encoding: 'utf-8', timeout: 10000, stdio: ['ignore', 'pipe', 'pipe'],
    });
  } catch (e) { return e.stdout || e.stderr || e.message; }
}

function handleSlash(input) {
  const cmd = input.trim().toLowerCase();
  if (cmd === '/exit' || cmd === '/quit') {
    console.log(`\n  ${C.dim}Goodbye.${C.reset}\n`);
    process.exit(0);
  }
  if (cmd === '/clear') { console.clear(); conversationHistory.length = 0; drawBanner(); return true; }
  if (cmd === '/help') { console.log(runJerikoSync('--help')); return true; }
  if (cmd === '/commands') { console.log(runJerikoSync('discover --list --format text')); return true; }
  if (cmd === '/memory') { console.log(runJerikoSync('memory --recent 10 --format text')); return true; }
  return false;
}

// ── Plan Tracker ────────────────────────────────────────────────────
// Tracks multi-step execution like Jeriko-Web's show_plan
function createPlanTracker() {
  const steps = [];
  let planTitle = null;

  return {
    get steps() { return steps; },
    get title() { return planTitle; },
    get total() { return steps.length; },
    get completed() { return steps.filter(s => s.status === 'completed').length; },
    get hasSteps() { return steps.length > 0; },

    setTitle(title) { planTitle = title; },

    addStep(command) {
      const step = {
        id: steps.length + 1,
        command: truncCmd(command),
        status: 'in_progress',   // pending | in_progress | completed | error
        startTime: Date.now(),
      };
      steps.push(step);
      return step;
    },

    completeStep(success) {
      const current = steps.find(s => s.status === 'in_progress');
      if (current) {
        current.status = success !== false ? 'completed' : 'error';
        current.elapsed = Date.now() - current.startTime;
      }
    },

    // Render the plan status bar (compact, Manus-style)
    renderStatus() {
      if (steps.length <= 1) return '';
      const done = steps.filter(s => s.status === 'completed').length;
      const total = steps.length;
      return `  ${progressBar(done, total, 20)}  ${C.gray}${done}/${total} steps${C.reset}`;
    },
  };
}

// ── Status Icons ────────────────────────────────────────────────────
function stepIcon(status) {
  switch (status) {
    case 'pending':     return `${C.gray}${SYM.circle}${C.reset}`;
    case 'in_progress': return `${C.cyan}${SYM.halfCircle}${C.reset}`;
    case 'completed':   return `${C.green}${SYM.check}${C.reset}`;
    case 'error':       return `${C.red}${SYM.cross}${C.reset}`;
    default:            return `${C.gray}${SYM.circle}${C.reset}`;
  }
}

// ── Response Renderer ───────────────────────────────────────────────
function createRenderer() {
  let responseStarted = false;
  const startTime = Date.now();
  const plan = createPlanTracker();

  return {
    get responseStarted() { return responseStarted; },
    get startTime() { return startTime; },
    get plan() { return plan; },

    // ── Thinking / Reasoning Text ──
    showThinkingText(text) {
      if (!text || !text.trim()) return;
      const lines = text.trim().split('\n');
      process.stdout.write(`\n`);

      // Show as a planning block
      process.stdout.write(`  ${C.dim}${SYM.topLeft}${SYM.hLine} ${C.italic}reasoning${C.reset}${C.dim} ${SYM.hLine.repeat(42)}${SYM.topRight}${C.reset}\n`);
      for (const line of lines) {
        const trimmed = line.trim();
        if (!trimmed) continue;
        process.stdout.write(`  ${C.dim}${SYM.bar}${C.reset} ${C.gray}${C.italic}${trimmed}${C.reset}\n`);
      }
      process.stdout.write(`  ${C.dim}${SYM.botLeft}${SYM.hLine.repeat(53)}${SYM.botRight}${C.reset}\n`);
    },

    // ── Tool Call (Step Start) ──
    showToolCall(command) {
      const step = plan.addStep(command);
      const num = step.id;
      const isFirst = num === 1;
      const connector = plan.total > 1 ? `${C.dim}${SYM.connect}${C.reset}` : ' ';

      if (isFirst) {
        process.stdout.write(`\n`);
      } else {
        // Connector line from previous step
        process.stdout.write(`  ${C.dim}${SYM.connect}${C.reset}\n`);
      }

      // Step header with number and command
      process.stdout.write(`  ${stepIcon('in_progress')} ${C.bold}${C.cyan}Step ${num}${C.reset} ${C.dim}${SYM.hLine.repeat(46)}${C.reset}\n`);
      process.stdout.write(`  ${C.dim}${SYM.connect}${C.reset} ${C.white}$ ${step.command}${C.reset}\n`);
    },

    // ── Tool Result (Step Complete) ──
    showToolResult(command, success) {
      plan.completeStep(success);
      const icon = success !== false
        ? `${C.green}${SYM.check}${C.reset}`
        : `${C.red}${SYM.cross}${C.reset}`;
      process.stdout.write(`  ${C.dim}${SYM.connect}${C.reset} ${icon} ${C.dim}done${C.reset}\n`);
    },

    // ── Response Start ──
    startResponse() {
      if (responseStarted) return;
      responseStarted = true;

      const dt = elapsed(Date.now() - startTime);
      const stepCount = plan.total;
      const stepsLabel = stepCount > 0
        ? ` ${C.gray}${SYM.dot} ${stepCount} step${stepCount > 1 ? 's' : ''}${C.reset}`
        : '';

      process.stdout.write(`\n`);

      // Progress bar if multi-step
      if (plan.total > 1) {
        process.stdout.write(`${plan.renderStatus()}\n\n`);
      }

      // Response header
      process.stdout.write(`  ${C.bold}${C.bCyan}jeriko${C.reset}${stepsLabel} ${C.gray}${dt}${C.reset}\n`);
      process.stdout.write(`  ${C.dim}${SYM.hLine.repeat(56)}${C.reset}\n`);
    },

    // ── Response Chunks ──
    writeChunk(text) {
      const lines = text.split('\n');
      for (let i = 0; i < lines.length; i++) {
        if (i < lines.length - 1) {
          process.stdout.write(`  ${C.white}${lines[i]}${C.reset}\n`);
        } else if (lines[i]) {
          process.stdout.write(`  ${C.white}${lines[i]}${C.reset}`);
        }
      }
    },

    // ── Finish ──
    finish() {
      const dt = elapsed(Date.now() - startTime);
      const stepCount = plan.total;
      process.stdout.write(`${C.reset}\n`);
      process.stdout.write(`  ${C.dim}${SYM.hLine.repeat(56)}${C.reset}\n`);

      // Footer with timing and step count
      const parts = [dt];
      if (stepCount > 0) parts.push(`${stepCount} tool call${stepCount > 1 ? 's' : ''}`);

      process.stdout.write(`  ${C.gray}${parts.join(` ${SYM.dot} `)}${C.reset}\n`);
      process.stdout.write('\n');
    },

    // ── Error ──
    showError(msg) {
      process.stdout.write(`${C.reset}\n`);
      process.stdout.write(`  ${C.red}${SYM.cross} error${C.reset} ${msg}\n\n`);
    },
  };
}

// ── Main REPL ───────────────────────────────────────────────────────
async function main() {
  try {
    require(path.join(__dirname, '..', 'lib', 'cli.js'));
  } catch { /* ignore */ }

  drawBanner();
  process.env.JERIKO_CHAT_QUIET = '1';

  const { route } = require(path.join(__dirname, '..', 'server', 'router.js'));

  const rl = readline.createInterface({
    input: process.stdin,
    output: process.stdout,
    prompt: `  ${C.cyan}${SYM.arrow}${C.reset} `,
    terminal: true,
  });

  rl.on('SIGINT', () => {
    console.log(`\n  ${C.dim}Goodbye.${C.reset}\n`);
    process.exit(0);
  });

  rl.prompt();

  rl.on('line', async (line) => {
    const input = line.trim();
    if (!input) { rl.prompt(); return; }
    if (input.startsWith('/') && handleSlash(input)) { rl.prompt(); return; }

    rl.pause();
    const spin = createSpinner();
    const render = createRenderer();

    const onStatus = (event) => {
      switch (event.type) {
        case 'thinking':
          if (!spin.active) spin.start('Thinking');
          break;

        case 'thinking_text':
          spin.stop();
          render.showThinkingText(event.text);
          break;

        case 'tool_call':
          spin.stop();
          render.showToolCall(event.command);
          spin.start('Running');
          break;

        case 'tool_result':
          spin.stop();
          render.showToolResult(event.command);
          break;

        case 'responding':
          spin.stop();
          render.startResponse();
          break;
      }
    };

    const onChunk = (text) => {
      if (spin.active) spin.stop();
      if (!render.responseStarted) render.startResponse();
      render.writeChunk(text);
    };

    try {
      spin.start('Thinking');
      await route(input, onChunk, onStatus, conversationHistory);
      spin.stop();

      if (render.responseStarted) {
        render.finish();
      } else {
        process.stdout.write(`\n  ${C.dim}(no response)${C.reset}\n\n`);
      }
    } catch (err) {
      spin.stop();
      render.showError(err.message);
    }

    rl.resume();
    rl.prompt();
  });

  rl.on('close', () => {
    console.log(`\n  ${C.dim}Goodbye.${C.reset}\n`);
    process.exit(0);
  });
}

main();
