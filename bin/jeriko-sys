#!/usr/bin/env node
const { parseArgs, ok, fail, run } = require('../lib/cli');
const { getSystemInfo, getProcesses, getNetworkInfo, getBattery } = require('../tools/system');

run(async () => {
  const { flags } = parseArgs(process.argv);

  if (flags.processes || flags.ps) {
    const limit = typeof flags.limit === 'string' ? parseInt(flags.limit, 10) : 10;
    return ok(await getProcesses({ limit }));
  }
  if (flags.network || flags.net) return ok(await getNetworkInfo());
  if (flags.battery) return ok(await getBattery());

  // Default: --info or no flags
  ok(await getSystemInfo());
});
