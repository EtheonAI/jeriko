#!/usr/bin/env node
const { parseArgs, ok, fail, run } = require('../lib/cli');
const browser = require('../tools/browser');

run(async () => {
  const { flags, positional } = parseArgs(process.argv);
  const results = {};

  // URL can come from --navigate value, --screenshot value, or first positional arg
  const url = (typeof flags.navigate === 'string' && flags.navigate)
    || (typeof flags.screenshot === 'string' && flags.screenshot)
    || positional[0];

  // 1. Navigate first
  if (url) {
    results.navigate = await browser.navigate(url);
  }

  // 2. Click
  if (flags.click) {
    if (typeof flags.click !== 'string') fail('Usage: jeriko browse --click <selector>');
    results.click = await browser.click(flags.click);
  }

  // 3. Type into fields
  if (flags.type) {
    if (typeof flags.type !== 'string') fail('Usage: jeriko browse --type <selector> --value <text>');
    const value = flags.value || positional[positional.length - 1] || '';
    results.type = await browser.type(flags.type, value);
  }

  // 4. Scroll
  if (flags.scroll) {
    const dir = typeof flags.scroll === 'string' ? flags.scroll : 'down';
    const times = flags.times ? parseInt(flags.times, 10) : 1;
    for (let i = 0; i < times; i++) {
      if (dir === 'up') await browser.scrollUp();
      else await browser.scrollDown();
    }
    results.scroll = { direction: dir, times };
  }

  // 5. Run JS
  if (flags.js) {
    if (typeof flags.js !== 'string') fail('Usage: jeriko browse --js <code>');
    results.js = await browser.evaluate(flags.js);
  }

  // 6. Wait for any navigation/animations to settle after interactions
  if (flags.click || flags.type || flags.scroll) {
    await new Promise(r => setTimeout(r, 1000));
  }

  // 7. Extract text
  if (flags.text) {
    results.text = await browser.getText();
  }

  // 8. Extract links
  if (flags.links) {
    results.links = await browser.getLinks();
  }

  // 9. Screenshot LAST — after all interactions
  if (flags.screenshot !== undefined) {
    const shot = await browser.screenshot({ fullPage: !!flags.full });
    results.screenshot = shot;
    process.stderr.write(`SCREENSHOT:${shot.path}\n`);
  }

  await browser.closeBrowser();

  if (Object.keys(results).length === 0) {
    fail('Usage: jeriko browse --navigate <url> [--screenshot] [--text] [--links] [--click <sel>] [--type <sel> --value <text>] [--scroll [up|down] --times N] [--js <code>]');
  }

  // If only one operation, unwrap
  const keys = Object.keys(results);
  ok(keys.length === 1 ? results[keys[0]] : results);
});
