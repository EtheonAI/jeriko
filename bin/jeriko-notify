#!/usr/bin/env node
const { parseArgs, ok, fail, readStdin, run, EXIT } = require('../lib/cli');
const fs = require('fs');
const path = require('path');

const API = 'https://api.telegram.org/bot';

run(async () => {
  const token = process.env.TELEGRAM_BOT_TOKEN;
  const chatIds = (process.env.ADMIN_TELEGRAM_IDS || '').split(',').map(s => s.trim()).filter(Boolean);

  if (!token) fail('TELEGRAM_BOT_TOKEN not set in .env', EXIT.AUTH);
  if (!chatIds.length) fail('ADMIN_TELEGRAM_IDS not set in .env', EXIT.AUTH);

  const { flags } = parseArgs(process.argv);
  const stdin = await readStdin(1000);

  // Determine what to send
  if (flags.photo) {
    const photoPath = typeof flags.photo === 'string' ? flags.photo : null;
    // If --photo - (dash), read path from stdin JSON
    let filePath = photoPath;
    if (photoPath === '-' && stdin) {
      try {
        const parsed = JSON.parse(stdin);
        filePath = parsed.data?.path || parsed.data?.screenshot?.path || parsed.path;
      } catch {
        filePath = stdin.trim();
      }
    }
    if (!filePath || !fs.existsSync(filePath)) fail(`Photo not found: ${filePath}`, EXIT.NOT_FOUND);

    const caption = flags.caption || flags.message || '';
    const results = [];
    for (const chatId of chatIds) {
      const form = new FormData();
      form.append('chat_id', chatId);
      form.append('photo', new Blob([fs.readFileSync(filePath)]), path.basename(filePath));
      if (caption) form.append('caption', caption);
      const res = await fetch(`${API}${token}/sendPhoto`, { method: 'POST', body: form });
      results.push(await res.json());
    }
    return ok(results.length === 1 ? results[0] : results);
  }

  if (flags.document) {
    const docPath = typeof flags.document === 'string' ? flags.document : null;
    if (!docPath || !fs.existsSync(docPath)) fail(`Document not found: ${docPath}`, EXIT.NOT_FOUND);

    const caption = flags.caption || '';
    const results = [];
    for (const chatId of chatIds) {
      const form = new FormData();
      form.append('chat_id', chatId);
      form.append('document', new Blob([fs.readFileSync(docPath)]), path.basename(docPath));
      if (caption) form.append('caption', caption);
      const res = await fetch(`${API}${token}/sendDocument`, { method: 'POST', body: form });
      results.push(await res.json());
    }
    return ok(results.length === 1 ? results[0] : results);
  }

  // Text message: --message or stdin
  let text = typeof flags.message === 'string' ? flags.message : null;

  if (!text && stdin) {
    // If stdin is JSON from another jeriko command, format it nicely
    try {
      const parsed = JSON.parse(stdin);
      if (parsed.ok && parsed.data) {
        text = typeof parsed.data === 'string' ? parsed.data : JSON.stringify(parsed.data, null, 2);
      } else {
        text = JSON.stringify(parsed, null, 2);
      }
    } catch {
      text = stdin.trim();
    }
  }

  if (!text) fail('Usage: jeriko notify --message <text> | --photo <path> | --document <path>');

  // Truncate to Telegram's 4096 char limit
  if (text.length > 4096) text = text.slice(0, 4093) + '...';

  const results = [];
  for (const chatId of chatIds) {
    const res = await fetch(`${API}${token}/sendMessage`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ chat_id: chatId, text }),
    });
    results.push(await res.json());
  }
  ok(results.length === 1 ? results[0] : results);
});
