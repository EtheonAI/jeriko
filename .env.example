# AI Backend: 'claude-code' (dev, default) | 'claude' (prod) | 'openai' | 'local' (Ollama/LM Studio)
# AI_BACKEND=claude-code

# Anthropic API key (for claude backend)
ANTHROPIC_API_KEY=
# Claude model (default: claude-sonnet-4-20250514)
# CLAUDE_MODEL=claude-sonnet-4-20250514

# OpenAI API key (for openai backend)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o

# Local model (for 'local' backend — Ollama, LM Studio, vLLM, llama.cpp, etc.)
# LOCAL_MODEL_URL=http://localhost:11434/v1
# LOCAL_MODEL=llama3.2
# LOCAL_API_KEY=

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Server port
PROXY_PORT=3000

# Comma-separated Telegram user IDs allowed to use the bot
ADMIN_TELEGRAM_IDS=

# Secret used to generate/validate node auth tokens
NODE_AUTH_SECRET=

# WhatsApp admin phone number (with country code, no +)
WHATSAPP_ADMIN_PHONE=

# Default machine name for commands without @prefix
DEFAULT_NODE=local

# Email — IMAP (read) + SMTP (send)
# Gmail: use an App Password, not your real password
# https://myaccount.google.com/apppasswords
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=
IMAP_PASSWORD=

# SMTP (optional — auto-detected from IMAP host if not set)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=

# Parallel engine (optional — for custom backends)
# PARALLEL_API_URL=
# PARALLEL_API_FORMAT=openai
# PARALLEL_API_KEY=

# Stripe (set via: /auth stripe <key> OR /connect stripe for OAuth)
# https://dashboard.stripe.com/apikeys
# STRIPE_SECRET_KEY=
# Stripe OAuth (for Stripe Apps — accessing other accounts)
# https://marketplace.stripe.com/oauth/v2/authorize
# STRIPE_OAUTH_CLIENT_ID=
# STRIPE_ACCESS_TOKEN=
# STRIPE_REFRESH_TOKEN=

# X.com / Twitter (set via: jeriko x init OR /connect x)
# https://developer.x.com/en/portal/dashboard
# X_BEARER_TOKEN=
# X_OAUTH_CLIENT_ID=
# X_OAUTH_CLIENT_SECRET=
# OAuth 1.0a for user-context writes:
# X_API_KEY=
# X_API_SECRET=
# X_ACCESS_TOKEN=
# X_ACCESS_TOKEN_SECRET=

# Twilio Voice (set via: jeriko twilio init)
# https://console.twilio.com
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=

# GitHub (set via: /auth github <token> OR /connect github)
# https://github.com/settings/tokens
# GITHUB_TOKEN=
# GITHUB_OAUTH_CLIENT_ID=
# GITHUB_OAUTH_CLIENT_SECRET=

# Vercel (set via: /auth vercel <token> OR /connect vercel)
# https://vercel.com/account/tokens
# Sign in with Vercel OAuth: Team Settings → Apps → Create
# https://vercel.com/docs/sign-in-with-vercel
# VERCEL_TOKEN=
# VERCEL_OAUTH_CLIENT_ID=
# VERCEL_OAUTH_CLIENT_SECRET=
# VERCEL_REFRESH_TOKEN=

# Google Drive (set via: /connect gdrive)
# https://console.cloud.google.com/apis/credentials
# GDRIVE_OAUTH_CLIENT_ID=
# GDRIVE_OAUTH_CLIENT_SECRET=
# GDRIVE_ACCESS_TOKEN=
# GDRIVE_REFRESH_TOKEN=

# OneDrive (set via: /connect onedrive)
# https://portal.azure.com/#view/Microsoft_AAD_RegisteredApps
# ONEDRIVE_OAUTH_CLIENT_ID=
# ONEDRIVE_OAUTH_CLIENT_SECRET=
# ONEDRIVE_ACCESS_TOKEN=
# ONEDRIVE_REFRESH_TOKEN=

# Gmail (set via: /connect gmail)
# https://console.cloud.google.com/apis/credentials
# GMAIL_OAUTH_CLIENT_ID=
# GMAIL_OAUTH_CLIENT_SECRET=
# GMAIL_ACCESS_TOKEN=
# GMAIL_REFRESH_TOKEN=

# Outlook (set via: /connect outlook)
# https://portal.azure.com/#view/Microsoft_AAD_RegisteredApps
# OUTLOOK_OAUTH_CLIENT_ID=
# OUTLOOK_OAUTH_CLIENT_SECRET=
# OUTLOOK_ACCESS_TOKEN=
# OUTLOOK_REFRESH_TOKEN=

# Tunnel (auto-set by jeriko init)
# TUNNEL_PROVIDER=          # 'cloudflare-named' (recommended) | 'cloudflare' (quick) | 'localtunnel'
# TUNNEL_NAME=              # Named tunnel name (e.g. 'Jeriko') — only for cloudflare-named
# TUNNEL_URL=               # Public URL (e.g. https://bot.jeriko.ai)
