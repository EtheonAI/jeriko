# AI Backend: 'claude-code' (dev, default) | 'claude' (prod) | 'openai' | 'local' (Ollama/LM Studio)
# AI_BACKEND=claude-code

# Anthropic API key (for claude backend)
ANTHROPIC_API_KEY=
# Claude model (default: claude-sonnet-4-20250514)
# CLAUDE_MODEL=claude-sonnet-4-20250514

# OpenAI API key (for openai backend)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o

# Local model (for 'local' backend — Ollama, LM Studio, vLLM, llama.cpp, etc.)
# LOCAL_MODEL_URL=http://localhost:11434/v1
# LOCAL_MODEL=llama3.2
# LOCAL_API_KEY=

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Server port
PROXY_PORT=3000

# Comma-separated Telegram user IDs allowed to use the bot
ADMIN_TELEGRAM_IDS=

# Secret used to generate/validate node auth tokens
NODE_AUTH_SECRET=

# WhatsApp admin phone number (with country code, no +)
WHATSAPP_ADMIN_PHONE=

# Default machine name for commands without @prefix
DEFAULT_NODE=local

# Email — IMAP (read) + SMTP (send)
# Gmail: use an App Password, not your real password
# https://myaccount.google.com/apppasswords
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=
IMAP_PASSWORD=

# SMTP (optional — auto-detected from IMAP host if not set)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=

# Parallel engine (optional — for custom backends)
# PARALLEL_API_URL=
# PARALLEL_API_FORMAT=openai
# PARALLEL_API_KEY=

# Stripe (set via: jeriko stripe init)
# https://dashboard.stripe.com/apikeys
# STRIPE_SECRET_KEY=

# X.com / Twitter (set via: jeriko x init)
# https://developer.x.com/en/portal/dashboard
# X_BEARER_TOKEN=
# X_CLIENT_ID=
# X_CLIENT_SECRET=

# Twilio Voice (set via: jeriko twilio init)
# https://console.twilio.com
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=

# GitHub (set via: jeriko github init)
# https://github.com/settings/tokens
# GITHUB_TOKEN=

# Vercel (set via: jeriko vercel init)
# https://vercel.com/account/tokens
# VERCEL_TOKEN=

# Google Drive (set via: jeriko gdrive init)
# https://console.cloud.google.com/apis/credentials
# GOOGLE_DRIVE_CLIENT_ID=
# GOOGLE_DRIVE_CLIENT_SECRET=
# GOOGLE_DRIVE_REFRESH_TOKEN=

# OneDrive (set via: jeriko onedrive init)
# https://portal.azure.com/#view/Microsoft_AAD_RegisteredApps
# ONEDRIVE_CLIENT_ID=
# ONEDRIVE_REFRESH_TOKEN=

# Tunnel (auto-set by jeriko init)
# TUNNEL_PROVIDER=          # 'cloudflare-named' (recommended) | 'cloudflare' (quick) | 'localtunnel'
# TUNNEL_NAME=              # Named tunnel name (e.g. 'Jeriko') — only for cloudflare-named
# TUNNEL_URL=               # Public URL (e.g. https://bot.jeriko.ai)
