{
  "name": "jeriko",
  "version": "2.0.0-alpha.15",
  "description": "Unix-first CLI toolkit for AI agents — commands replace proprietary tool abstractions",
  "type": "module",
  "main": "src/index.ts",
  "bin": {
    "jeriko": "./src/index.ts"
  },
  "files": [
    "src/",
    "scripts/install.sh",
    "templates/",
    "AGENT.md",
    ".env.example",
    "tsconfig.json",
    "drizzle.config.ts",
    "bunfig.toml"
  ],
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts server start --foreground",
    "build": "bun run scripts/build.ts",
    "build:darwin-arm64": "bun run scripts/build.ts --target darwin-arm64",
    "build:darwin-x64": "bun run scripts/build.ts --target darwin-x64",
    "build:linux-arm64": "bun run scripts/build.ts --target linux-arm64",
    "build:linux-x64": "bun run scripts/build.ts --target linux-x64",
    "build:windows-x64": "bun run scripts/build.ts --target windows-x64",
    "build:all": "bun run scripts/build.ts --all",
    "test": "bun test",
    "test:unit": "bun test test/unit/",
    "test:unit:billing": "bun test test/unit/billing/",
    "test:unit:cli": "bun test test/unit/cli/",
    "test:unit:agent": "bun test test/unit/orchestrator.test.ts test/unit/orchestrator-context.test.ts test/unit/agent-guard.test.ts test/unit/model-system.test.ts test/unit/model-registry.test.ts test/unit/tool-registry.test.ts",
    "test:unit:channels": "bun test test/unit/channel-router.test.ts test/unit/channel-adapters.test.ts",
    "test:unit:connectors": "bun test test/unit/connectors.test.ts test/unit/oauth.test.ts test/unit/gmail-outlook.test.ts",
    "test:unit:triggers": "bun test test/unit/trigger-engine.test.ts test/unit/trigger-routes.test.ts test/unit/email-trigger.test.ts",
    "test:unit:relay": "bun test test/unit/relay-client.test.ts test/unit/relay-protocol.test.ts test/unit/relay-connections.test.ts test/unit/urls.test.ts",
    "test:unit:security": "bun test test/unit/security.test.ts test/unit/api-security.test.ts test/unit/escape.test.ts",
    "test:unit:shared": "bun test test/unit/output.test.ts test/unit/bus.test.ts test/unit/args.test.ts test/unit/config.test.ts test/unit/tokens.test.ts test/unit/env-ref.test.ts test/unit/db.test.ts test/unit/signal.test.ts test/unit/binding.test.ts test/unit/user-id.test.ts test/unit/install-user-id.test.ts test/unit/self-install.test.ts test/unit/dispatcher.test.ts",
    "test:unit:skills": "bun test test/unit/skill-loader.test.ts test/unit/skill-tool.test.ts",
    "test:unit:webdev": "bun test test/unit/webdev-tool.test.ts test/unit/browser-scripts.test.ts",
    "test:unit:streaming": "bun test test/unit/socket-stream.test.ts test/unit/openai-stream.test.ts test/unit/providers.test.ts test/unit/claude-code-driver.test.ts",
    "test:integration": "bun test test/integration/",
    "test:integration:relay": "bun test test/integration/relay-e2e.test.ts",
    "test:integration:commands": "bun test test/integration/commands.test.ts",
    "test:integration:connectors": "bun test test/integration/channel-connectors.test.ts",
    "test:e2e": "bun test test/e2e/",
    "test:smoke": "bun test test/smoke/",
    "test:ci": "bun test test/unit/ && bun test test/integration/ && bun test test/e2e/",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit && echo 'Type check passed'",
    "check": "tsc --noEmit",
    "website:dev": "bun run --cwd apps/website dev -- --port 3002",
    "website:build": "bun run --cwd apps/website build",
    "website:start": "bun run --cwd apps/website start -- --port 3002"
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "os": [
    "darwin",
    "linux",
    "win32"
  ],
  "cpu": [
    "x64",
    "arm64"
  ],
  "keywords": [
    "cli",
    "ai",
    "agent",
    "automation",
    "unix",
    "macos",
    "linux",
    "windows",
    "daemon",
    "tools",
    "telegram",
    "whatsapp"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/etheonai/jeriko.git"
  },
  "homepage": "https://jeriko.ai",
  "license": "MIT",
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "@whiskeysockets/baileys": "^6.7.16",
    "chalk": "^5.4.0",
    "croner": "^10.0.1",
    "drizzle-orm": "^0.39.0",
    "grammy": "^1.35.0",
    "hono": "^4.7.0",
    "ink": "6.8.0",
    "playwright-core": "^1.58.2",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "react": "^19.0.0",
    "stripe": "^20.4.0",
    "ws": "^8.18.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@stripe/ui-extension-sdk": "^9.1.0",
    "@types/bun": "latest",
    "@types/node": "^25.3.2",
    "@types/react": "^19.0.2",
    "@types/ws": "^8.5.0",
    "drizzle-kit": "^0.30.0",
    "ink-testing-library": "^4.0.0",
    "typescript": "^5.7.0"
  }
}
