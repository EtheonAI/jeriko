{
  "name": "jeriko",
  "version": "2.0.0-alpha.0",
  "description": "Unix-first CLI toolkit for AI agents — commands replace proprietary tool abstractions",
  "type": "module",
  "main": "src/index.ts",
  "bin": {
    "jeriko": "./src/index.ts"
  },
  "files": [
    "src/",
    "scripts/install.sh",
    "templates/",
    "AGENT.md",
    ".env.example",
    "tsconfig.json",
    "drizzle.config.ts",
    "bunfig.toml"
  ],
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "bun --preload ./node_modules/@opentui/solid/scripts/preload.ts --conditions=browser --watch src/index.ts",
    "start": "bun --preload ./node_modules/@opentui/solid/scripts/preload.ts --conditions=browser src/index.ts server start --foreground",
    "build": "bun run scripts/build.ts",
    "build:darwin-arm64": "bun run scripts/build.ts --target darwin-arm64",
    "build:darwin-x64": "bun run scripts/build.ts --target darwin-x64",
    "build:linux-arm64": "bun run scripts/build.ts --target linux-arm64",
    "build:linux-x64": "bun run scripts/build.ts --target linux-x64",
    "build:windows-x64": "bun run scripts/build.ts --target windows-x64",
    "build:all": "bun run scripts/build.ts --all",
    "test": "bun test",
    "test:unit": "bun test test/unit/",
    "test:integration": "bun test test/integration/",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit && echo 'Type check passed'",
    "check": "tsc --noEmit",
    "website:dev": "bun run --cwd apps/website dev -- --port 3002",
    "website:build": "bun run --cwd apps/website build",
    "website:start": "bun run --cwd apps/website start -- --port 3002"
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "os": [
    "darwin",
    "linux",
    "win32"
  ],
  "cpu": [
    "x64",
    "arm64"
  ],
  "keywords": [
    "cli",
    "ai",
    "agent",
    "automation",
    "unix",
    "macos",
    "linux",
    "windows",
    "daemon",
    "tools",
    "telegram",
    "whatsapp"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/khaleel737/jeriko.git"
  },
  "homepage": "https://jeriko.ai",
  "license": "MIT",
  "dependencies": {
    "@opentui/core": "^0.1.84",
    "@opentui/core-darwin-x64": "0.1.84",
    "@opentui/solid": "^0.1.84",
    "@whiskeysockets/baileys": "^6.7.16",
    "croner": "^10.0.1",
    "drizzle-orm": "^0.39.0",
    "grammy": "^1.35.0",
    "hono": "^4.7.0",
    "playwright-core": "^1.58.2",
    "solid-js": "^1.9.11",
    "ws": "^8.18.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^25.3.2",
    "@types/ws": "^8.5.0",
    "drizzle-kit": "^0.30.0",
    "typescript": "^5.7.0"
  }
}
